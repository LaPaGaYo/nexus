#!/usr/bin/env bash
# nexus setup — build browser binary + register skills with Claude Code / Codex
set -e

if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  echo "Install with checksum verification:" >&2
  echo '  BUN_VERSION="1.3.10"' >&2
  echo '  tmpfile=$(mktemp)' >&2
  echo '  curl -fsSL "https://bun.sh/install" -o "$tmpfile"' >&2
  echo '  echo "Verify checksum before running: shasum -a 256 $tmpfile"' >&2
  echo '  BUN_VERSION="$BUN_VERSION" bash "$tmpfile" && rm "$tmpfile"' >&2
  exit 1
fi

INSTALL_NEXUS_DIR="$(cd "$(dirname "$0")" && pwd)"
SOURCE_NEXUS_DIR="$(cd "$(dirname "$0")" && pwd -P)"
INSTALL_SKILLS_DIR="$(dirname "$INSTALL_NEXUS_DIR")"
BROWSE_BIN="$SOURCE_NEXUS_DIR/browse/dist/browse"
CODEX_SKILLS="$HOME/.codex/skills"
CODEX_NEXUS="$CODEX_SKILLS/nexus"
FACTORY_SKILLS="$HOME/.factory/skills"
FACTORY_NEXUS="$FACTORY_SKILLS/nexus"

IS_WINDOWS=0
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*|Windows_NT) IS_WINDOWS=1 ;;
esac

# ─── Parse flags ──────────────────────────────────────────────
HOST="claude"
LOCAL_INSTALL=0
SKILL_PREFIX=1
SKILL_PREFIX_FLAG=0
while [ $# -gt 0 ]; do
  case "$1" in
    --host) [ -z "$2" ] && echo "Missing value for --host (expected claude, codex, kiro, or auto)" >&2 && exit 1; HOST="$2"; shift 2 ;;
    --host=*) HOST="${1#--host=}"; shift ;;
    --local) LOCAL_INSTALL=1; shift ;;
    --prefix)    SKILL_PREFIX=1; SKILL_PREFIX_FLAG=1; shift ;;
    --no-prefix) SKILL_PREFIX=0; SKILL_PREFIX_FLAG=1; shift ;;
    *) shift ;;
  esac
done

case "$HOST" in
  claude|codex|kiro|factory|auto) ;;
  *) echo "Unknown --host value: $HOST (expected claude, codex, kiro, factory, or auto)" >&2; exit 1 ;;
esac

# ─── Resolve skill prefix preference ─────────────────────────
# Priority: CLI flag > saved config > interactive prompt (or flat default for non-TTY)
NEXUS_CONFIG="$SOURCE_NEXUS_DIR/bin/nexus-config"
GLOBAL_CLAUDE_HELPER="$SOURCE_NEXUS_DIR/bin/nexus-global-claude"
export NEXUS_SETUP_RUNNING=1  # Prevent nexus-config post-set hook from triggering relink mid-setup
if [ "$SKILL_PREFIX_FLAG" -eq 0 ]; then
  _saved_prefix="$("$NEXUS_CONFIG" get skill_prefix 2>/dev/null || true)"
  if [ "$_saved_prefix" = "true" ]; then
    SKILL_PREFIX=1
  elif [ "$_saved_prefix" = "false" ]; then
    SKILL_PREFIX=0
  else
    # No saved preference — prompt interactively (or default flat for non-TTY)
    if [ -t 0 ]; then
      echo ""
      echo "Skill naming: how should Nexus skills appear?"
      echo ""
      echo "  1) Short names: /qa, /ship, /review"
      echo "     Recommended. Clean and fast to type."
      echo ""
      echo "  2) Namespaced: /nexus-qa, /nexus-ship, /nexus-review"
      echo "     Use this if you run other skill packs alongside Nexus to avoid conflicts."
      echo ""
      printf "Choice [1/2] (default: 1, auto-selects in 10s): "
      read -t 10 -r _prefix_choice </dev/tty 2>/dev/null || _prefix_choice=""
      case "$_prefix_choice" in
        2) SKILL_PREFIX=1 ;;
        *) SKILL_PREFIX=0 ;;
      esac
    else
      SKILL_PREFIX=0
    fi
    # Save the choice for future runs
    "$NEXUS_CONFIG" set skill_prefix "$([ "$SKILL_PREFIX" -eq 1 ] && echo true || echo false)" 2>/dev/null || true
  fi
else
  # Flag was passed explicitly — persist the choice
  "$NEXUS_CONFIG" set skill_prefix "$([ "$SKILL_PREFIX" -eq 1 ] && echo true || echo false)" 2>/dev/null || true
fi

maybe_offer_global_claude_guidance() {
  [ "$INSTALL_CLAUDE" -eq 1 ] || return 0
  [ "$LOCAL_INSTALL" -eq 0 ] || return 0
  [ -t 0 ] || return 0
  [ -x "$GLOBAL_CLAUDE_HELPER" ] || return 0

  _global_declined="$("$NEXUS_CONFIG" get global_claude_declined 2>/dev/null || echo "false")"
  [ "$_global_declined" = "true" ] && return 0

  if "$GLOBAL_CLAUDE_HELPER" status >/dev/null 2>&1; then
    return 0
  fi

  echo ""
  echo "Global Claude guidance: should Nexus update ~/.claude/CLAUDE.md?"
  echo ""
  echo "  1) Add Nexus-first guidance to ~/.claude/CLAUDE.md (recommended)"
  echo "     Claude will route lifecycle work through Nexus globally."
  echo ""
  echo "  2) Skip for now"
  echo "     Leaves your global Claude instructions unchanged."
  echo ""
  printf "Choice [1/2] (default: 2, auto-selects in 10s): "
  read -t 10 -r _global_choice </dev/tty 2>/dev/null || _global_choice=""
  case "$_global_choice" in
    1)
      _global_target="$("$GLOBAL_CLAUDE_HELPER" apply)"
      "$NEXUS_CONFIG" set global_claude_declined false 2>/dev/null || true
      echo "  updated global CLAUDE.md: $_global_target"
      ;;
    *)
      "$NEXUS_CONFIG" set global_claude_declined true 2>/dev/null || true
      echo "  skipped global CLAUDE.md update"
      ;;
  esac
}

maybe_offer_execution_mode_choice() {
  [ "$INSTALL_CLAUDE" -eq 1 ] || return 0
  [ -t 0 ] || return 0
  command -v ask >/dev/null 2>&1 || return 0

  _mode="$("$NEXUS_CONFIG" get execution_mode 2>/dev/null || true)"
  [ -n "$_mode" ] && return 0

  echo ""
  echo "Execution mode: CCB was detected on this machine. How should Nexus run?"
  echo ""
  echo "  1) Continue in the current Claude session (local_provider)"
  echo "     Recommended if you want to keep working in this Claude window right now."
  echo ""
  echo "  2) Use tmux + CCB for governed multi-model runs (governed_ccb)"
  echo "     Requires restarting Claude inside: tmux && ccb codex gemini claude"
  echo ""
  printf "Choice [1/2] (default: 1, auto-selects in 10s): "
  read -t 10 -r _execution_choice </dev/tty 2>/dev/null || _execution_choice=""

  case "$_execution_choice" in
    2)
      "$NEXUS_CONFIG" set execution_mode governed_ccb 2>/dev/null || true
      echo "  selected governed_ccb"
      echo "  next: finish setup, then relaunch Claude inside tmux with: ccb codex gemini claude"
      ;;
    *)
      "$NEXUS_CONFIG" set execution_mode local_provider 2>/dev/null || true
      "$NEXUS_CONFIG" set primary_provider claude 2>/dev/null || true
      echo "  selected local_provider (claude)"
      echo "  next: you can keep using the current Claude session"
      ;;
  esac
}

supports_local_claude_subagents() {
  command -v claude >/dev/null 2>&1 || return 1

  if ! _claude_help="$(claude --help 2>&1)"; then
    return 1
  fi
  printf '%s' "$_claude_help" | grep -q -- '--agents' || return 1
  printf '%s' "$_claude_help" | grep -q -- '--agent' || return 1
}

maybe_offer_local_topology_choice() {
  [ "$INSTALL_CLAUDE" -eq 1 ] || return 0
  [ -t 0 ] || return 0
  command -v claude >/dev/null 2>&1 || return 0

  _mode="$("$NEXUS_CONFIG" get execution_mode 2>/dev/null || true)"
  if [ -z "$_mode" ]; then
    if command -v ask >/dev/null 2>&1; then
      _mode="governed_ccb"
    else
      _mode="local_provider"
    fi
  fi
  [ "$_mode" = "local_provider" ] || return 0

  _provider="$("$NEXUS_CONFIG" get primary_provider 2>/dev/null || true)"
  [ -n "$_provider" ] || _provider="claude"
  [ "$_provider" = "claude" ] || return 0

  _topology="$("$NEXUS_CONFIG" get provider_topology 2>/dev/null || true)"
  [ -n "$_topology" ] && return 0

  if ! supports_local_claude_subagents; then
    "$NEXUS_CONFIG" set provider_topology single_agent 2>/dev/null || true
    echo ""
    echo "Local Claude topology: subagents are unavailable with the installed claude CLI."
    echo "  selected local_provider (claude, single_agent)"
    return 0
  fi

  echo ""
  echo "Local Claude topology: how should Nexus run without CCB?"
  echo ""
  echo "  1) single_agent"
  echo "     One Claude local execution path. Lowest friction."
  echo ""
  echo "  2) subagents"
  echo "     Claude local subagents for build, review, and QA."
  echo ""
  printf "Choice [1/2] (default: 1, auto-selects in 10s): "
  read -t 10 -r _topology_choice </dev/tty 2>/dev/null || _topology_choice=""

  case "$_topology_choice" in
    2)
      "$NEXUS_CONFIG" set provider_topology subagents 2>/dev/null || true
      echo "  selected local_provider (claude, subagents)"
      ;;
    *)
      "$NEXUS_CONFIG" set provider_topology single_agent 2>/dev/null || true
      echo "  selected local_provider (claude, single_agent)"
      ;;
  esac
}

announce_execution_mode() {
  [ -x "$NEXUS_CONFIG" ] || return 0

  _mode="$("$NEXUS_CONFIG" get execution_mode 2>/dev/null || true)"
  _provider="$("$NEXUS_CONFIG" get primary_provider 2>/dev/null || true)"
  _topology="$("$NEXUS_CONFIG" get provider_topology 2>/dev/null || true)"

  if [ -z "$_mode" ]; then
    if command -v ask >/dev/null 2>&1; then
      _mode="governed_ccb"
    else
      _mode="local_provider"
    fi
  fi

  if [ "$_mode" = "governed_ccb" ]; then
    echo "  execution: governed_ccb (CCB transport)"
    echo "  session: use tmux + 'ccb codex gemini claude' for governed runs"
    return 0
  fi

  if [ -z "$_provider" ]; then
    if command -v claude >/dev/null 2>&1; then
      _provider="claude"
    elif command -v codex >/dev/null 2>&1; then
      _provider="codex"
    elif command -v gemini >/dev/null 2>&1; then
      _provider="gemini"
    else
      _provider="claude"
    fi
  fi

  [ -n "$_topology" ] || _topology="single_agent"
  if ! command -v "$_provider" >/dev/null 2>&1; then
    echo "  execution: local_provider (${_provider}, ${_topology}) [provider CLI missing]"
    echo "  note: /handoff will block until ${_provider} is installed or execution_mode is switched to governed_ccb"
    return 0
  fi
  echo "  execution: local_provider (${_provider}, ${_topology})"
}

# --local: install to .claude/skills/ in the current working directory
if [ "$LOCAL_INSTALL" -eq 1 ]; then
  if [ "$HOST" = "codex" ]; then
    echo "Error: --local is only supported for Claude Code (not Codex)." >&2
    exit 1
  fi
  INSTALL_SKILLS_DIR="$(pwd)/.claude/skills"
  mkdir -p "$INSTALL_SKILLS_DIR"
  HOST="claude"
  INSTALL_CODEX=0
fi

# For auto: detect which agents are installed
INSTALL_CLAUDE=0
INSTALL_CODEX=0
INSTALL_KIRO=0
INSTALL_FACTORY=0
if [ "$HOST" = "auto" ]; then
  command -v claude >/dev/null 2>&1 && INSTALL_CLAUDE=1
  command -v codex >/dev/null 2>&1 && INSTALL_CODEX=1
  command -v kiro-cli >/dev/null 2>&1 && INSTALL_KIRO=1
  command -v droid >/dev/null 2>&1 && INSTALL_FACTORY=1
  # If none found, default to claude
  if [ "$INSTALL_CLAUDE" -eq 0 ] && [ "$INSTALL_CODEX" -eq 0 ] && [ "$INSTALL_KIRO" -eq 0 ] && [ "$INSTALL_FACTORY" -eq 0 ]; then
    INSTALL_CLAUDE=1
  fi
elif [ "$HOST" = "claude" ]; then
  INSTALL_CLAUDE=1
elif [ "$HOST" = "codex" ]; then
  INSTALL_CODEX=1
elif [ "$HOST" = "kiro" ]; then
  INSTALL_KIRO=1
elif [ "$HOST" = "factory" ]; then
  INSTALL_FACTORY=1
fi

migrate_direct_codex_install() {
  local nexus_dir="$1"
  local codex_nexus="$2"
  local migrated_dir="$HOME/.nexus/repos/nexus"

  [ "$nexus_dir" = "$codex_nexus" ] || return 0
  [ -L "$nexus_dir" ] && return 0

  mkdir -p "$(dirname "$migrated_dir")"
  if [ -e "$migrated_dir" ] && [ "$migrated_dir" != "$nexus_dir" ]; then
    echo "nexus setup failed: direct Codex install detected at $nexus_dir" >&2
    echo "A migrated repo already exists at $migrated_dir; move one of them aside and rerun setup." >&2
    exit 1
  fi

  echo "Migrating direct Codex install to $migrated_dir to avoid duplicate skill discovery..."
  mv "$nexus_dir" "$migrated_dir"
  SOURCE_NEXUS_DIR="$migrated_dir"
  INSTALL_NEXUS_DIR="$migrated_dir"
  INSTALL_SKILLS_DIR="$(dirname "$INSTALL_NEXUS_DIR")"
  BROWSE_BIN="$SOURCE_NEXUS_DIR/browse/dist/browse"
}

if [ "$INSTALL_CODEX" -eq 1 ]; then
  migrate_direct_codex_install "$SOURCE_NEXUS_DIR" "$CODEX_NEXUS"
fi

ensure_playwright_browser() {
  if [ "$IS_WINDOWS" -eq 1 ]; then
    # On Windows, Bun can't launch Chromium due to broken pipe handling
    # (oven-sh/bun#4253). Use Node.js to verify Chromium works instead.
    (
      cd "$SOURCE_NEXUS_DIR"
      node -e "const { chromium } = require('playwright'); (async () => { const b = await chromium.launch(); await b.close(); })()" 2>/dev/null
    )
  else
    (
      cd "$SOURCE_NEXUS_DIR"
      bun --eval 'import { chromium } from "playwright"; const browser = await chromium.launch(); await browser.close();'
    ) >/dev/null 2>&1
  fi
}

# 1. Build browse binary if needed (smart rebuild: stale sources, package.json, lock)
NEEDS_BUILD=0
if [ ! -x "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -n "$(find "$SOURCE_NEXUS_DIR/browse/src" -type f -newer "$BROWSE_BIN" -print -quit 2>/dev/null)" ]; then
  NEEDS_BUILD=1
elif [ "$SOURCE_NEXUS_DIR/package.json" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -f "$SOURCE_NEXUS_DIR/bun.lock" ] && [ "$SOURCE_NEXUS_DIR/bun.lock" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
fi

if [ "$NEEDS_BUILD" -eq 1 ]; then
  echo "Building browse binary..."
  (
    cd "$SOURCE_NEXUS_DIR"
    bun install
    bun run build
  )
  # Safety net: write .version if build script didn't (e.g., git not available during build)
  if [ ! -f "$SOURCE_NEXUS_DIR/browse/dist/.version" ]; then
    git -C "$SOURCE_NEXUS_DIR" rev-parse HEAD > "$SOURCE_NEXUS_DIR/browse/dist/.version" 2>/dev/null || true
  fi
fi

if [ ! -x "$BROWSE_BIN" ]; then
  echo "nexus setup failed: browse binary missing at $BROWSE_BIN" >&2
  exit 1
fi

# 1b. Generate .agents/ Codex skill docs — always regenerate to prevent stale descriptions.
# .agents/ is no longer committed — generated at setup time from .tmpl templates.
# bun run build already does this, but we need it when NEEDS_BUILD=0 (binary is fresh).
# Always regenerate: generation is fast (<2s) and mtime-based staleness checks are fragile
# (miss stale files when timestamps match after clone/checkout/upgrade).
AGENTS_DIR="$SOURCE_NEXUS_DIR/.agents/skills"
NEEDS_AGENTS_GEN=1

if [ "$NEEDS_AGENTS_GEN" -eq 1 ] && [ "$NEEDS_BUILD" -eq 0 ]; then
  echo "Generating .agents/ skill docs..."
  (
    cd "$SOURCE_NEXUS_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run gen:skill-docs --host codex
  )
fi

# 1c. Generate .factory/ Factory Droid skill docs
if [ "$INSTALL_FACTORY" -eq 1 ] && [ "$NEEDS_BUILD" -eq 0 ]; then
  echo "Generating .factory/ skill docs..."
  (
    cd "$SOURCE_NEXUS_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run gen:skill-docs --host factory
  )
fi

# 2. Ensure Playwright's Chromium is available
if ! ensure_playwright_browser; then
  echo "Installing Playwright Chromium..."
  (
    cd "$SOURCE_NEXUS_DIR"
    bunx playwright install chromium
  )

  if [ "$IS_WINDOWS" -eq 1 ]; then
    # On Windows, Node.js launches Chromium (not Bun — see oven-sh/bun#4253).
    # Ensure playwright is importable by Node from the Nexus directory.
    if ! command -v node >/dev/null 2>&1; then
      echo "nexus setup failed: Node.js is required on Windows (Bun cannot launch Chromium due to a pipe bug)" >&2
      echo "  Install Node.js: https://nodejs.org/" >&2
      exit 1
    fi
    echo "Windows detected — verifying Node.js can load Playwright..."
    (
      cd "$SOURCE_NEXUS_DIR"
      # Bun's node_modules already has playwright; verify Node can require it
      node -e "require('playwright')" 2>/dev/null || npm install --no-save playwright
    )
  fi
fi

if ! ensure_playwright_browser; then
  if [ "$IS_WINDOWS" -eq 1 ]; then
    echo "nexus setup failed: Playwright Chromium could not be launched via Node.js" >&2
    echo "  This is a known issue with Bun on Windows (oven-sh/bun#4253)." >&2
    echo "  Ensure Node.js is installed and 'node -e \"require('playwright')\"' works." >&2
  else
    echo "nexus setup failed: Playwright Chromium could not be launched" >&2
  fi
  exit 1
fi

# 3. Ensure ~/.nexus global state directory exists
NEXUS_STATE_DIR="$HOME/.nexus"
mkdir -p "$NEXUS_STATE_DIR/projects"

# ─── Helper: link Claude skill subdirectories into a skills parent directory ──
# When SKILL_PREFIX=1, symlinks are prefixed with "nexus-" to make Nexus the
# visible namespace owner (e.g., nexus-review instead of review).
# Use --no-prefix to restore the old flat names.
link_claude_skill_dirs() {
  local nexus_dir="$1"
  local skills_dir="$2"
  local linked=()
  for skill_dir in "$nexus_dir"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      dir_name="$(basename "$skill_dir")"
      # Skip node_modules
      [ "$dir_name" = "node_modules" ] && continue
      # Use frontmatter name: if present (e.g., run-tests/ with name: test → symlink as "test")
      skill_name=$(grep -m1 '^name:' "$skill_dir/SKILL.md" 2>/dev/null | sed 's/^name:[[:space:]]*//' | tr -d '[:space:]')
      [ -z "$skill_name" ] && skill_name="$dir_name"
      # Apply nexus- prefix unless --no-prefix or already inherently prefixed
      if [ "$SKILL_PREFIX" -eq 1 ]; then
        case "$skill_name" in
          nexus-*) link_name="$skill_name" ;;
          *)       link_name="nexus-$skill_name" ;;
        esac
      else
        link_name="$skill_name"
      fi
      target="$skills_dir/$link_name"
      # Create or update symlink; skip if a real file/directory exists
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "nexus/$dir_name" "$target"
        linked+=("$link_name")
      fi
      if [ "$SKILL_PREFIX" -eq 1 ]; then
        case "$skill_name" in
          nexus-*) ;;
          *)
            [ -L "$skills_dir/$skill_name" ] && rm -f "$skills_dir/$skill_name"
            ;;
        esac
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

# ─── Helper: remove old unprefixed Claude skill symlinks ──────────────────────
# Migration: when switching from flat names to nexus- prefixed names,
# clean up stale symlinks that point into the Nexus runtime directory.
cleanup_old_claude_symlinks() {
  local nexus_dir="$1"
  local skills_dir="$2"
  local removed=()
  for skill_dir in "$nexus_dir"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      [ "$skill_name" = "node_modules" ] && continue
      # Skip already-prefixed dirs (nexus-upgrade) — no old symlink to clean
      case "$skill_name" in nexus-*) continue ;; esac
      old_target="$skills_dir/$skill_name"
      # Only remove if it's a symlink pointing into nexus/
      if [ -L "$old_target" ]; then
        link_dest="$(readlink "$old_target" 2>/dev/null || true)"
        case "$link_dest" in
          nexus/*|*/nexus/*)
            rm -f "$old_target"
            removed+=("$skill_name")
            ;;
        esac
      fi
    fi
  done
  if [ ${#removed[@]} -gt 0 ]; then
    echo "  cleaned up old symlinks: ${removed[*]}"
  fi
}

# ─── Helper: remove old prefixed Claude skill symlinks ────────────────────────
# Reverse migration: when switching from prefixed names to flat names,
# clean up stale nexus-* symlinks that point into the Nexus runtime directory.
cleanup_prefixed_claude_symlinks() {
  local nexus_dir="$1"
  local skills_dir="$2"
  local removed=()
  for skill_dir in "$nexus_dir"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      [ "$skill_name" = "node_modules" ] && continue
      # Only clean up prefixed symlinks for dirs that AREN'T already prefixed
      # (e.g., remove nexus-qa but NOT nexus-upgrade which is the real dir name)
      case "$skill_name" in nexus-*) continue ;; esac
      for prefixed_target in "$skills_dir/nexus-$skill_name"; do
        if [ -L "$prefixed_target" ]; then
          link_dest="$(readlink "$prefixed_target" 2>/dev/null || true)"
          case "$link_dest" in
            nexus/*|*/nexus/*)
              rm -f "$prefixed_target"
              removed+=("$(basename "$prefixed_target")")
              ;;
          esac
        fi
      done
    fi
  done
  if [ ${#removed[@]} -gt 0 ]; then
    echo "  cleaned up prefixed symlinks: ${removed[*]}"
  fi
}

# ─── Helper: link generated Codex skills into a skills parent directory ──
# Installs from .agents/skills/nexus-* (the generated Codex-format skills)
# instead of source dirs (which have Claude paths).
link_codex_skill_dirs() {
  local nexus_dir="$1"
  local skills_dir="$2"
  local agents_dir="$nexus_dir/.agents/skills"
  local linked=()

  if [ ! -d "$agents_dir" ]; then
    echo "  Generating .agents/ skill docs..."
    ( cd "$nexus_dir" && bun run gen:skill-docs --host codex )
  fi

  if [ ! -d "$agents_dir" ]; then
    echo "  warning: .agents/skills/ generation failed — run 'bun run gen:skill-docs --host codex' manually" >&2
    return 1
  fi

  for skill_dir in "$agents_dir"/nexus*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      # Skip the sidecar directory — it contains runtime asset symlinks (bin/,
      # browse/), not a skill. Linking it would overwrite the root nexus
      # symlink that Step 5 already pointed at the repo root.
      [ "$skill_name" = "nexus" ] && continue
      target="$skills_dir/$skill_name"
      # Create or update symlink
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "$skill_dir" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

# ─── Helper: create .agents/skills/nexus/ sidecar symlinks ──────────
# Codex/Gemini/Cursor read skills from .agents/skills/. We link runtime
# assets (bin/, browse/dist/, review/, qa/, etc.) so skill templates can
# resolve paths like $SKILL_ROOT/review/design-checklist.md.
create_agents_sidecar() {
  local repo_root="$1"
  local agents_nexus="$repo_root/.agents/skills/nexus"
  mkdir -p "$agents_nexus"

  # Sidecar directories that skills reference at runtime
  for asset in bin browse review qa; do
    local src="$SOURCE_NEXUS_DIR/$asset"
    local dst="$agents_nexus/$asset"
    if [ -d "$src" ] || [ -f "$src" ]; then
      if [ -L "$dst" ] || [ ! -e "$dst" ]; then
        ln -snf "$src" "$dst"
      fi
    fi
  done

  # Sidecar files that skills reference at runtime
  for file in ETHOS.md; do
    local src="$SOURCE_NEXUS_DIR/$file"
    local dst="$agents_nexus/$file"
    if [ -f "$src" ]; then
      if [ -L "$dst" ] || [ ! -e "$dst" ]; then
        ln -snf "$src" "$dst"
      fi
    fi
  done
}

# ─── Helper: create a minimal ~/.codex/skills/nexus runtime root ───────────
# Codex scans ~/.codex/skills recursively. Exposing the whole repo here causes
# duplicate skills because source SKILL.md files and generated Codex skills are
# both discoverable. Keep this directory limited to runtime assets + root skill.
create_codex_runtime_root() {
  local nexus_dir="$1"
  local codex_nexus="$2"
  local agents_dir="$nexus_dir/.agents/skills"

  if [ -L "$codex_nexus" ]; then
    rm -f "$codex_nexus"
  elif [ -d "$codex_nexus" ] && [ "$codex_nexus" != "$nexus_dir" ]; then
    # Old direct installs left a real directory here with stale source skills.
    # Remove it so we start fresh with only the minimal runtime assets.
    rm -rf "$codex_nexus"
  fi

  mkdir -p "$codex_nexus" "$codex_nexus/browse" "$codex_nexus/nexus-upgrade" "$codex_nexus/review"

  if [ -f "$agents_dir/nexus/SKILL.md" ]; then
    ln -snf "$agents_dir/nexus/SKILL.md" "$codex_nexus/SKILL.md"
  fi
  if [ -d "$nexus_dir/bin" ]; then
    ln -snf "$nexus_dir/bin" "$codex_nexus/bin"
  fi
  if [ -d "$nexus_dir/browse/dist" ]; then
    ln -snf "$nexus_dir/browse/dist" "$codex_nexus/browse/dist"
  fi
  if [ -d "$nexus_dir/browse/bin" ]; then
    ln -snf "$nexus_dir/browse/bin" "$codex_nexus/browse/bin"
  fi
  if [ -f "$agents_dir/nexus-upgrade/SKILL.md" ]; then
    ln -snf "$agents_dir/nexus-upgrade/SKILL.md" "$codex_nexus/nexus-upgrade/SKILL.md"
  fi
  # Review runtime assets (individual files, NOT the whole review/ dir which has SKILL.md)
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$nexus_dir/review/$f" ]; then
      ln -snf "$nexus_dir/review/$f" "$codex_nexus/review/$f"
    fi
  done
  # ETHOS.md — referenced by "Search Before Building" in all skill preambles
  if [ -f "$nexus_dir/ETHOS.md" ]; then
    ln -snf "$nexus_dir/ETHOS.md" "$codex_nexus/ETHOS.md"
  fi
}

create_factory_runtime_root() {
  local nexus_dir="$1"
  local factory_nexus="$2"
  local factory_dir="$nexus_dir/.factory/skills"

  if [ -L "$factory_nexus" ]; then
    rm -f "$factory_nexus"
  elif [ -d "$factory_nexus" ] && [ "$factory_nexus" != "$nexus_dir" ]; then
    rm -rf "$factory_nexus"
  fi

  mkdir -p "$factory_nexus" "$factory_nexus/browse" "$factory_nexus/nexus-upgrade" "$factory_nexus/review"

  if [ -f "$factory_dir/nexus/SKILL.md" ]; then
    ln -snf "$factory_dir/nexus/SKILL.md" "$factory_nexus/SKILL.md"
  fi
  if [ -d "$nexus_dir/bin" ]; then
    ln -snf "$nexus_dir/bin" "$factory_nexus/bin"
  fi
  if [ -d "$nexus_dir/browse/dist" ]; then
    ln -snf "$nexus_dir/browse/dist" "$factory_nexus/browse/dist"
  fi
  if [ -d "$nexus_dir/browse/bin" ]; then
    ln -snf "$nexus_dir/browse/bin" "$factory_nexus/browse/bin"
  fi
  if [ -f "$factory_dir/nexus-upgrade/SKILL.md" ]; then
    ln -snf "$factory_dir/nexus-upgrade/SKILL.md" "$factory_nexus/nexus-upgrade/SKILL.md"
  fi
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$nexus_dir/review/$f" ]; then
      ln -snf "$nexus_dir/review/$f" "$factory_nexus/review/$f"
    fi
  done
  if [ -f "$nexus_dir/ETHOS.md" ]; then
    ln -snf "$nexus_dir/ETHOS.md" "$factory_nexus/ETHOS.md"
  fi
}

link_factory_skill_dirs() {
  local nexus_dir="$1"
  local skills_dir="$2"
  local factory_dir="$nexus_dir/.factory/skills"
  local linked=()

  if [ ! -d "$factory_dir" ]; then
    echo "  Generating .factory/ skill docs..."
    ( cd "$nexus_dir" && bun run gen:skill-docs --host factory )
  fi

  if [ ! -d "$factory_dir" ]; then
    echo "  warning: .factory/skills/ generation failed — run 'bun run gen:skill-docs --host factory' manually" >&2
    return 1
  fi

  for skill_dir in "$factory_dir"/nexus*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      [ "$skill_name" = "nexus" ] && continue
      target="$skills_dir/$skill_name"
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "$skill_dir" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

# 4. Install for Claude (default)
SKILLS_BASENAME="$(basename "$INSTALL_SKILLS_DIR")"
SKILLS_PARENT_BASENAME="$(basename "$(dirname "$INSTALL_SKILLS_DIR")")"
CODEX_REPO_LOCAL=0
if [ "$SKILLS_BASENAME" = "skills" ] && [ "$SKILLS_PARENT_BASENAME" = ".agents" ]; then
  CODEX_REPO_LOCAL=1
fi

if [ "$INSTALL_CLAUDE" -eq 1 ]; then
  if [ "$SKILLS_BASENAME" = "skills" ]; then
    # Clean up stale symlinks from the opposite prefix mode
    if [ "$SKILL_PREFIX" -eq 1 ]; then
      cleanup_old_claude_symlinks "$SOURCE_NEXUS_DIR" "$INSTALL_SKILLS_DIR"
    else
      cleanup_prefixed_claude_symlinks "$SOURCE_NEXUS_DIR" "$INSTALL_SKILLS_DIR"
    fi
    # Patch name: fields BEFORE creating symlinks so link_claude_skill_dirs
    # reads the correct (patched) name: values for symlink naming
    "$SOURCE_NEXUS_DIR/bin/nexus-patch-names" "$SOURCE_NEXUS_DIR" "$SKILL_PREFIX"
    link_claude_skill_dirs "$SOURCE_NEXUS_DIR" "$INSTALL_SKILLS_DIR"
    if [ "$LOCAL_INSTALL" -eq 1 ]; then
      echo "Nexus ready (project-local)."
      echo "  skills: $INSTALL_SKILLS_DIR"
    else
      echo "Nexus ready (claude)."
    fi
    maybe_offer_execution_mode_choice
    maybe_offer_local_topology_choice
    maybe_offer_global_claude_guidance
    echo "  browse: $BROWSE_BIN"
    announce_execution_mode
  else
    echo "Nexus ready (claude)."
    maybe_offer_execution_mode_choice
    maybe_offer_local_topology_choice
    maybe_offer_global_claude_guidance
    echo "  browse: $BROWSE_BIN"
    announce_execution_mode
    echo "  (skipped skill symlinks — not inside .claude/skills/)"
  fi
fi

# 5. Install for Codex
if [ "$INSTALL_CODEX" -eq 1 ]; then
  if [ "$CODEX_REPO_LOCAL" -eq 1 ]; then
    CODEX_SKILLS="$INSTALL_SKILLS_DIR"
    CODEX_NEXUS="$INSTALL_NEXUS_DIR"
  fi
  mkdir -p "$CODEX_SKILLS"

  # Skip runtime root creation for repo-local installs — the checkout IS the runtime root.
  # create_codex_runtime_root would create self-referential symlinks (bin → bin, etc.).
  if [ "$CODEX_REPO_LOCAL" -eq 0 ]; then
    create_codex_runtime_root "$SOURCE_NEXUS_DIR" "$CODEX_NEXUS"
  fi
  # Install generated Codex-format skills (not Claude source dirs)
  link_codex_skill_dirs "$SOURCE_NEXUS_DIR" "$CODEX_SKILLS"

  echo "Nexus ready (codex)."
  echo "  browse: $BROWSE_BIN"
  echo "  codex skills: $CODEX_SKILLS"
  announce_execution_mode
fi

# 6. Install for Kiro CLI (copy from .agents/skills, rewrite paths)
if [ "$INSTALL_KIRO" -eq 1 ]; then
  KIRO_SKILLS="$HOME/.kiro/skills"
  AGENTS_DIR="$SOURCE_NEXUS_DIR/.agents/skills"
  mkdir -p "$KIRO_SKILLS"

  # Create the Nexus runtime dir with symlinks for runtime assets, copy+sed for SKILL.md
  KIRO_NEXUS="$KIRO_SKILLS/nexus"
  # Remove old whole-dir symlink from previous installs
  [ -L "$KIRO_NEXUS" ] && rm -f "$KIRO_NEXUS"
  mkdir -p "$KIRO_NEXUS" "$KIRO_NEXUS/browse" "$KIRO_NEXUS/nexus-upgrade" "$KIRO_NEXUS/review"
  ln -snf "$SOURCE_NEXUS_DIR/bin" "$KIRO_NEXUS/bin"
  ln -snf "$SOURCE_NEXUS_DIR/browse/dist" "$KIRO_NEXUS/browse/dist"
  ln -snf "$SOURCE_NEXUS_DIR/browse/bin" "$KIRO_NEXUS/browse/bin"
  # ETHOS.md — referenced by "Search Before Building" in all skill preambles
  if [ -f "$SOURCE_NEXUS_DIR/ETHOS.md" ]; then
    ln -snf "$SOURCE_NEXUS_DIR/ETHOS.md" "$KIRO_NEXUS/ETHOS.md"
  fi
  # nexus-upgrade skill
  if [ -f "$AGENTS_DIR/nexus-upgrade/SKILL.md" ]; then
    ln -snf "$AGENTS_DIR/nexus-upgrade/SKILL.md" "$KIRO_NEXUS/nexus-upgrade/SKILL.md"
  fi
  # Review runtime assets (individual files, not whole dir)
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$SOURCE_NEXUS_DIR/review/$f" ]; then
      ln -snf "$SOURCE_NEXUS_DIR/review/$f" "$KIRO_NEXUS/review/$f"
    fi
  done

  # Rewrite root SKILL.md paths for Kiro
  sed -e "s|~/.claude/skills/nexus|~/.kiro/skills/nexus|g" \
      -e "s|\.claude/skills/nexus|.kiro/skills/nexus|g" \
      -e "s|\.claude/skills|.kiro/skills|g" \
      "$SOURCE_NEXUS_DIR/SKILL.md" > "$KIRO_NEXUS/SKILL.md"

  if [ ! -d "$AGENTS_DIR" ]; then
    echo "  warning: no .agents/skills/ directory found — run 'bun run build' first" >&2
  else
    for skill_dir in "$AGENTS_DIR"/nexus*/; do
      [ -f "$skill_dir/SKILL.md" ] || continue
      skill_name="$(basename "$skill_dir")"
      target_dir="$KIRO_SKILLS/$skill_name"
      mkdir -p "$target_dir"
      # Generated Codex skills use $HOME/.codex (not ~/), plus $NEXUS_ROOT variables.
      # Rewrite the default NEXUS_ROOT value and any remaining literal paths.
      sed -e 's|\$HOME/.codex/skills/nexus|$HOME/.kiro/skills/nexus|g' \
          -e "s|~/.codex/skills/nexus|~/.kiro/skills/nexus|g" \
          -e "s|~/.claude/skills/nexus|~/.kiro/skills/nexus|g" \
          "$skill_dir/SKILL.md" > "$target_dir/SKILL.md"
    done
    echo "Nexus ready (kiro)."
    echo "  browse: $BROWSE_BIN"
    echo "  kiro skills: $KIRO_SKILLS"
    announce_execution_mode
  fi
fi

# 6b. Install for Factory Droid
if [ "$INSTALL_FACTORY" -eq 1 ]; then
  mkdir -p "$FACTORY_SKILLS"
  create_factory_runtime_root "$SOURCE_NEXUS_DIR" "$FACTORY_NEXUS"
  link_factory_skill_dirs "$SOURCE_NEXUS_DIR" "$FACTORY_SKILLS"
  echo "Nexus ready (factory)."
  echo "  browse: $BROWSE_BIN"
  echo "  factory skills: $FACTORY_SKILLS"
  announce_execution_mode
fi

# 7. Create .agents/ sidecar symlinks for the real Codex skill target.
# The root Codex skill ends up pointing at $SOURCE_NEXUS_DIR/.agents/skills/nexus,
# so the runtime assets must live there for both global and repo-local installs.
if [ "$INSTALL_CODEX" -eq 1 ]; then
  create_agents_sidecar "$SOURCE_NEXUS_DIR"
fi

# 8. First-time welcome + legacy cleanup
if [ ! -f "$HOME/.nexus/.welcome-seen" ]; then
  echo "  Welcome to Nexus! Run /nexus-upgrade anytime to stay current."
  echo "  Host helpers: nexus-config, nexus-relink, nexus-uninstall"
  touch "$HOME/.nexus/.welcome-seen"
fi
rm -f /tmp/nexus-latest-version
