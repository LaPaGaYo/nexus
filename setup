        ln -snf "$skill_dir" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

# 4. Install for Claude (default)
SKILLS_BASENAME="$(basename "$INSTALL_SKILLS_DIR")"
SKILLS_PARENT_BASENAME="$(basename "$(dirname "$INSTALL_SKILLS_DIR")")"
CODEX_REPO_LOCAL=0
if [ "$SKILLS_BASENAME" = "skills" ] && [ "$SKILLS_PARENT_BASENAME" = ".agents" ]; then
  CODEX_REPO_LOCAL=1
fi

if [ "$INSTALL_CLAUDE" -eq 1 ]; then
  if [ "$SKILLS_BASENAME" = "skills" ]; then
    # Clean up stale symlinks from the opposite prefix mode
    if [ "$SKILL_PREFIX" -eq 1 ]; then
      cleanup_old_claude_symlinks "$SOURCE_NEXUS_DIR" "$INSTALL_SKILLS_DIR"
    else
      cleanup_prefixed_claude_symlinks "$SOURCE_NEXUS_DIR" "$INSTALL_SKILLS_DIR"
      quarantine_claude_canonical_skill_conflicts "$INSTALL_SKILLS_DIR"
    fi
    quarantine_global_agents_canonical_skill_conflicts "$GLOBAL_AGENTS_SKILLS"
    # Patch name: fields BEFORE creating symlinks so link_claude_skill_dirs
    # reads the correct (patched) name: values for symlink naming
    "$SOURCE_NEXUS_DIR/bin/nexus-patch-names" "$SOURCE_NEXUS_DIR" "$SKILL_PREFIX"
    link_claude_skill_dirs "$SOURCE_NEXUS_DIR" "$INSTALL_SKILLS_DIR"
    if [ "$LOCAL_INSTALL" -eq 1 ]; then
      echo "Nexus ready (project-local)."
      echo "  skills: $INSTALL_SKILLS_DIR"
    else
      echo "Nexus ready (claude)."
    fi
    maybe_clean_legacy_claude_hooks
    maybe_clean_stale_claude_sessions
    maybe_offer_ccb_install_choice
    maybe_offer_execution_mode_choice
    maybe_offer_local_topology_choice
    maybe_offer_global_claude_guidance
    echo "  browse: $BROWSE_BIN"
    announce_execution_mode
  else
    echo "Nexus ready (claude)."
    maybe_clean_legacy_claude_hooks
    maybe_clean_stale_claude_sessions
    maybe_offer_ccb_install_choice
    maybe_offer_execution_mode_choice
    maybe_offer_local_topology_choice
    maybe_offer_global_claude_guidance
    echo "  browse: $BROWSE_BIN"
    announce_execution_mode
    echo "  (skipped skill symlinks — not inside .claude/skills/)"
  fi
fi

# 5. Install for Codex
if [ "$INSTALL_CODEX" -eq 1 ]; then
  if [ "$CODEX_REPO_LOCAL" -eq 1 ]; then
    CODEX_SKILLS="$INSTALL_SKILLS_DIR"
    CODEX_NEXUS="$INSTALL_NEXUS_DIR"
  fi
  mkdir -p "$CODEX_SKILLS"
  quarantine_global_agents_canonical_skill_conflicts "$GLOBAL_AGENTS_SKILLS"

  # Skip runtime root creation for repo-local installs — the checkout IS the runtime root.
  # create_codex_runtime_root would create self-referential symlinks (bin → bin, etc.).
  if [ "$CODEX_REPO_LOCAL" -eq 0 ]; then
    create_codex_runtime_root "$SOURCE_NEXUS_DIR" "$CODEX_NEXUS"
  fi
  # Install generated Codex-format skills (not Claude source dirs)
  link_codex_skill_dirs "$SOURCE_NEXUS_DIR" "$CODEX_SKILLS"

  echo "Nexus ready (codex)."
  echo "  browse: $BROWSE_BIN"
  echo "  codex skills: $CODEX_SKILLS"
  echo "  next: use the installed nexus-* skills directly from Codex"
  echo "  note: Codex does not use a Nexus-managed global instruction file equivalent to ~/.claude/CLAUDE.md"
  announce_execution_mode
fi

# 6. Install for Gemini CLI
if [ "$INSTALL_GEMINI" -eq 1 ]; then
  mkdir -p "$GEMINI_SKILLS"
  create_gemini_runtime_root "$SOURCE_NEXUS_DIR" "$GEMINI_NEXUS"
  link_gemini_skill_dirs "$SOURCE_NEXUS_DIR" "$GEMINI_SKILLS"
  echo "Nexus ready (gemini-cli)."
  echo "  browse: $BROWSE_BIN"
  echo "  gemini skills: $GEMINI_SKILLS"
  echo "  next: run /skills reload in Gemini CLI if a session is already open"
  announce_execution_mode
fi

# 7. Install for Kiro CLI (copy from .agents/skills, rewrite paths)
if [ "$INSTALL_KIRO" -eq 1 ]; then
  KIRO_SKILLS="$HOME/.kiro/skills"
  AGENTS_DIR="$SOURCE_NEXUS_DIR/.agents/skills"
  mkdir -p "$KIRO_SKILLS"

  # Create the Nexus runtime dir with symlinks for runtime assets, copy+sed for SKILL.md
  KIRO_NEXUS="$KIRO_SKILLS/nexus"
  # Remove old whole-dir symlink from previous installs
  [ -L "$KIRO_NEXUS" ] && rm -f "$KIRO_NEXUS"
  mkdir -p "$KIRO_NEXUS" "$KIRO_NEXUS/browse" "$KIRO_NEXUS/design" "$KIRO_NEXUS/nexus-upgrade" "$KIRO_NEXUS/review"
  ln -snf "$SOURCE_NEXUS_DIR/bin" "$KIRO_NEXUS/bin"
  # ETHOS.md — referenced by "Search Before Building" in all skill preambles
  if [ -f "$SOURCE_NEXUS_DIR/ETHOS.md" ]; then
    ln -snf "$SOURCE_NEXUS_DIR/ETHOS.md" "$KIRO_NEXUS/ETHOS.md"
  fi
  # nexus-upgrade skill
  if [ -f "$AGENTS_DIR/nexus-upgrade/SKILL.md" ]; then
    ln -snf "$AGENTS_DIR/nexus-upgrade/SKILL.md" "$KIRO_NEXUS/nexus-upgrade/SKILL.md"
  fi
  link_runtime_compat_assets "$SOURCE_NEXUS_DIR" "$KIRO_NEXUS"
  link_reference_compat_assets "$SOURCE_NEXUS_DIR" "$KIRO_NEXUS"

  # Rewrite root SKILL.md paths for Kiro
  sed -e "s|~/.claude/skills/nexus|~/.kiro/skills/nexus|g" \
      -e "s|\.claude/skills/nexus|.kiro/skills/nexus|g" \
      -e "s|\.claude/skills|.kiro/skills|g" \
      "$SOURCE_NEXUS_DIR/SKILL.md" > "$KIRO_NEXUS/SKILL.md"

  if [ ! -d "$AGENTS_DIR" ]; then
    echo "  warning: no .agents/skills/ directory found — run 'bun run build' first" >&2
  else
    for skill_dir in "$AGENTS_DIR"/nexus*/; do
      [ -f "$skill_dir/SKILL.md" ] || continue
      skill_name="$(basename "$skill_dir")"
      target_dir="$KIRO_SKILLS/$skill_name"
      mkdir -p "$target_dir"
      # Generated Codex skills use $HOME/.codex (not ~/), plus $NEXUS_ROOT variables.
      # Rewrite the default NEXUS_ROOT value and any remaining literal paths.
      sed -e 's|\$HOME/.codex/skills/nexus|$HOME/.kiro/skills/nexus|g' \
          -e "s|~/.codex/skills/nexus|~/.kiro/skills/nexus|g" \
          -e "s|~/.claude/skills/nexus|~/.kiro/skills/nexus|g" \
          "$skill_dir/SKILL.md" > "$target_dir/SKILL.md"
    done
    echo "Nexus ready (kiro)."
    echo "  browse: $BROWSE_BIN"
    echo "  kiro skills: $KIRO_SKILLS"
    announce_execution_mode
  fi
fi

# 6b. Install for Factory Droid
if [ "$INSTALL_FACTORY" -eq 1 ]; then
  mkdir -p "$FACTORY_SKILLS"
  create_factory_runtime_root "$SOURCE_NEXUS_DIR" "$FACTORY_NEXUS"
  link_factory_skill_dirs "$SOURCE_NEXUS_DIR" "$FACTORY_SKILLS"
  echo "Nexus ready (factory)."
  echo "  browse: $BROWSE_BIN"
  echo "  factory skills: $FACTORY_SKILLS"
  announce_execution_mode
fi

# 7. Create .agents/ sidecar symlinks for the real Codex skill target.
# The root Codex skill ends up pointing at $SOURCE_NEXUS_DIR/.agents/skills/nexus,
# so the runtime assets must live there for both global and repo-local installs.
if [ "$INSTALL_CODEX" -eq 1 ]; then
  create_agents_sidecar "$SOURCE_NEXUS_DIR"
fi

# 8. First-time welcome + legacy cleanup
if [ ! -f "$HOME/.nexus/.welcome-seen" ]; then
  echo "  Welcome to Nexus! Run /nexus-upgrade anytime to stay current."
  echo "  Host helpers: nexus-config, nexus-relink, nexus-uninstall"
  touch "$HOME/.nexus/.welcome-seen"
fi
rm -f /tmp/nexus-latest-version
