#!/usr/bin/env bash
# nexus setup — build browser binary + register skills with Claude Code / Codex
set -e

if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  echo "Install with checksum verification:" >&2
  echo '  BUN_VERSION="1.3.10"' >&2
  echo '  tmpfile=$(mktemp)' >&2
  echo '  curl -fsSL "https://bun.sh/install" -o "$tmpfile"' >&2
  echo '  echo "Verify checksum before running: shasum -a 256 $tmpfile"' >&2
  echo '  BUN_VERSION="$BUN_VERSION" bash "$tmpfile" && rm "$tmpfile"' >&2
  exit 1
fi

INSTALL_NEXUS_DIR="$(cd "$(dirname "$0")" && pwd)"
SOURCE_NEXUS_DIR="$(cd "$(dirname "$0")" && pwd -P)"
INSTALL_SKILLS_DIR="$(dirname "$INSTALL_NEXUS_DIR")"
BROWSE_BIN="$SOURCE_NEXUS_DIR/runtimes/browse/dist/browse"
DESIGN_BIN="$SOURCE_NEXUS_DIR/runtimes/design/dist/design"
CODEX_SKILLS="$HOME/.codex/skills"
CODEX_NEXUS="$CODEX_SKILLS/nexus"
GEMINI_SKILLS="$HOME/.gemini/skills"
GEMINI_NEXUS="$GEMINI_SKILLS/nexus"
GLOBAL_AGENTS_SKILLS="$HOME/.agents/skills"
FACTORY_SKILLS="$HOME/.factory/skills"
FACTORY_NEXUS="$FACTORY_SKILLS/nexus"

IS_WINDOWS=0
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*|Windows_NT) IS_WINDOWS=1 ;;
esac

# ─── Parse flags ──────────────────────────────────────────────
HOST="claude"
LOCAL_INSTALL=0
SKILL_PREFIX=1
SKILL_PREFIX_FLAG=0
while [ $# -gt 0 ]; do
  case "$1" in
    --host) [ -z "$2" ] && echo "Missing value for --host (expected claude, codex, gemini-cli, gemini, kiro, factory, or auto)" >&2 && exit 1; HOST="$2"; shift 2 ;;
    --host=*) HOST="${1#--host=}"; shift ;;
    --local) LOCAL_INSTALL=1; shift ;;
    --prefix)    SKILL_PREFIX=1; SKILL_PREFIX_FLAG=1; shift ;;
    --no-prefix) SKILL_PREFIX=0; SKILL_PREFIX_FLAG=1; shift ;;
    *) shift ;;
  esac
done

case "$HOST" in
  claude|codex|gemini-cli|gemini|kiro|factory|auto) ;;
  *) echo "Unknown --host value: $HOST (expected claude, codex, gemini-cli, gemini, kiro, factory, or auto)" >&2; exit 1 ;;
esac

# ─── Resolve skill prefix preference ─────────────────────────
# Priority: CLI flag > saved config > interactive prompt (or flat default for non-TTY)
NEXUS_CONFIG="$SOURCE_NEXUS_DIR/bin/nexus-config"
GLOBAL_CLAUDE_HELPER="$SOURCE_NEXUS_DIR/bin/nexus-global-claude"
LEGACY_CLAUDE_HOOKS_HELPER="$SOURCE_NEXUS_DIR/bin/nexus-clean-claude-hooks"
LEGACY_CLAUDE_SESSIONS_HELPER="$SOURCE_NEXUS_DIR/bin/nexus-clean-claude-sessions"
CCB_REPO_URL="${NEXUS_CCB_REPO_URL:-https://github.com/bfly123/claude_code_bridge.git}"
export NEXUS_SETUP_RUNNING=1  # Prevent nexus-config post-set hook from triggering relink mid-setup
if [ "$SKILL_PREFIX_FLAG" -eq 0 ]; then
  _saved_prefix="$("$NEXUS_CONFIG" get skill_prefix 2>/dev/null || true)"
  if [ "$_saved_prefix" = "true" ]; then
    SKILL_PREFIX=1
  elif [ "$_saved_prefix" = "false" ]; then
    SKILL_PREFIX=0
  else
    # No saved preference — prompt interactively (or default flat for non-TTY)
    if [ -t 0 ]; then
      echo ""
      echo "Skill naming: how should Nexus skills appear?"
      echo ""
      echo "  1) Short names: /qa, /ship, /review"
      echo "     Recommended. Clean and fast to type."
      echo ""
      echo "  2) Namespaced: /nexus-qa, /nexus-ship, /nexus-review"
      echo "     Use this if you run other skill packs alongside Nexus to avoid conflicts."
      echo ""
      printf "Choice [1/2] (default: 1, auto-selects in 10s): "
      read -t 10 -r _prefix_choice </dev/tty 2>/dev/null || _prefix_choice=""
      case "$_prefix_choice" in
        2) SKILL_PREFIX=1 ;;
        *) SKILL_PREFIX=0 ;;
      esac
    else
      SKILL_PREFIX=0
    fi
    # Save the choice for future runs
    "$NEXUS_CONFIG" set skill_prefix "$([ "$SKILL_PREFIX" -eq 1 ] && echo true || echo false)" 2>/dev/null || true
  fi
else
  # Flag was passed explicitly — persist the choice
  "$NEXUS_CONFIG" set skill_prefix "$([ "$SKILL_PREFIX" -eq 1 ] && echo true || echo false)" 2>/dev/null || true
fi

maybe_offer_global_claude_guidance() {
  [ "$INSTALL_CLAUDE" -eq 1 ] || return 0
  [ "$LOCAL_INSTALL" -eq 0 ] || return 0
  [ -t 0 ] || return 0
  [ -x "$GLOBAL_CLAUDE_HELPER" ] || return 0

  _global_declined="$("$NEXUS_CONFIG" get global_claude_declined 2>/dev/null || echo "false")"
  [ "$_global_declined" = "true" ] && return 0

  if "$GLOBAL_CLAUDE_HELPER" status >/dev/null 2>&1; then
    return 0
  fi

  echo ""
  echo "Global Claude guidance: should Nexus update ~/.claude/CLAUDE.md?"
  echo ""
  echo "  1) Add Nexus-first guidance to ~/.claude/CLAUDE.md (recommended)"
  echo "     Claude will route lifecycle work through Nexus globally."
  echo ""
  echo "  2) Skip for now"
  echo "     Leaves your global Claude instructions unchanged."
  echo ""
  printf "Choice [1/2] (default: 2, auto-selects in 10s): "
  read -t 10 -r _global_choice </dev/tty 2>/dev/null || _global_choice=""
  case "$_global_choice" in
    1)
      _global_target="$("$GLOBAL_CLAUDE_HELPER" apply)"
      "$NEXUS_CONFIG" set global_claude_declined false 2>/dev/null || true
      echo "  updated global CLAUDE.md: $_global_target"
      ;;
    *)
      "$NEXUS_CONFIG" set global_claude_declined true 2>/dev/null || true
      echo "  skipped global CLAUDE.md update"
      ;;
  esac
}

maybe_clean_legacy_claude_hooks() {
  [ "$INSTALL_CLAUDE" -eq 1 ] || return 0
  [ -x "$LEGACY_CLAUDE_HOOKS_HELPER" ] || return 0

  _cleanup_output="$("$LEGACY_CLAUDE_HOOKS_HELPER" apply 2>/dev/null || true)"
  [ -z "$_cleanup_output" ] && return 0
  [ "$_cleanup_output" = "clean" ] && return 0

  echo ""
  echo "Legacy Claude hook cleanup:"
  printf '%s\n' "$_cleanup_output" | while IFS= read -r _cleaned_path; do
    [ -n "$_cleaned_path" ] && echo "  removed legacy GSD hook entries from: $_cleaned_path"
  done
}

maybe_clean_stale_claude_sessions() {
  [ "$INSTALL_CLAUDE" -eq 1 ] || return 0
  [ -x "$LEGACY_CLAUDE_SESSIONS_HELPER" ] || return 0

  _cleanup_output="$("$LEGACY_CLAUDE_SESSIONS_HELPER" apply 2>/dev/null || true)"
  [ -z "$_cleanup_output" ] && return 0
  [ "$_cleanup_output" = "clean" ] && return 0

  echo ""
  echo "Stale Claude session cleanup:"
  printf '%s\n' "$_cleanup_output" | while IFS= read -r _cleaned_path; do
    [ -n "$_cleaned_path" ] && echo "  removed stale Nexus session transcript: $_cleaned_path"
  done
}

ensure_local_bin_on_path() {
  case ":$PATH:" in
    *":$HOME/.local/bin:"*) ;;
    *) export PATH="$HOME/.local/bin:$PATH" ;;
  esac
}

ask_available() {
  if command -v ask >/dev/null 2>&1; then
    return 0
  fi
  if [ -x "$HOME/.local/bin/ask" ]; then
    ensure_local_bin_on_path
    return 0
  fi
  if [ -x "$HOME/.local/share/codex-dual/bin/ask" ]; then
    ensure_local_bin_on_path
    return 0
  fi
  return 1
}

install_ccb_now() {
  ensure_local_bin_on_path
  ask_available && return 0

  if ! command -v git >/dev/null 2>&1; then
    echo "Error: git is required to install CCB." >&2
    return 1
  fi

  _ccb_tmp="$(mktemp -d "${TMPDIR:-/tmp}/nexus-ccb.XXXXXX")"

  echo "  cloning CCB from $CCB_REPO_URL"
  if ! git clone --single-branch --depth 1 "$CCB_REPO_URL" "$_ccb_tmp/claude_code_bridge"; then
    rm -rf "$_ccb_tmp"
    echo "Error: failed to clone claude_code_bridge." >&2
    return 1
  fi

  echo "  running CCB installer"
  if ! (
    cd "$_ccb_tmp/claude_code_bridge" &&
    ./install.sh install
  ); then
    rm -rf "$_ccb_tmp"
    echo "Error: CCB installer exited unsuccessfully." >&2
    return 1
  fi

  ensure_local_bin_on_path
  if ! ask_available; then
    rm -rf "$_ccb_tmp"
    return 1
  fi
  rm -rf "$_ccb_tmp"
  return 0
}

maybe_offer_ccb_install_choice() {
  [ "$INSTALL_CLAUDE" -eq 1 ] || return 0
  [ -t 0 ] || return 0
  ask_available && return 0

  _mode="$("$NEXUS_CONFIG" get execution_mode 2>/dev/null || true)"
  [ "$_mode" = "local_provider" ] && return 0

  echo ""
  echo "CCB was not detected on this machine."
  echo ""
  echo "  1) Install CCB now (recommended for governed multi-model runs)"
  echo "     Nexus will clone the official claude_code_bridge repo and run ./install.sh install."
  echo ""
  echo "  2) Continue without CCB and use local_provider"
  echo "     You can keep working in this Claude session without governed multi-model routing."
  echo ""
  printf "Choice [1/2] (default: 2, auto-selects in 10s): "
  read -t 10 -r _ccb_choice </dev/tty 2>/dev/null || _ccb_choice=""

  case "$_ccb_choice" in
    1)
      echo "  installing CCB..."
      if install_ccb_now; then
        echo "  CCB install complete"
        return 0
      fi
      echo "Error: CCB installation failed. Re-run ./setup after fixing the installer output above." >&2
      return 1
      ;;
    *)
      "$NEXUS_CONFIG" set execution_mode local_provider 2>/dev/null || true
      "$NEXUS_CONFIG" set primary_provider claude 2>/dev/null || true
      echo "  continuing without CCB"
      echo "  selected local_provider (claude)"
      ;;
  esac
}

maybe_offer_execution_mode_choice() {
  [ "$INSTALL_CLAUDE" -eq 1 ] || return 0
  [ -t 0 ] || return 0
  ask_available || return 0

  _mode="$("$NEXUS_CONFIG" get execution_mode 2>/dev/null || true)"
  [ -n "$_mode" ] && return 0

  echo ""
  echo "Execution mode: CCB was detected on this machine. How should Nexus run?"
  echo ""
  echo "  1) Continue in the current Claude session (local_provider)"
  echo "     Recommended if you want to keep working in this Claude window right now."
  echo ""
  echo "  2) Use tmux + CCB for governed multi-model runs (governed_ccb)"
  echo "     Standard path: if CCB providers are not already mounted for this repo, start them with: tmux && ccb codex gemini claude"
  echo ""
  printf "Choice [1/2] (required): "
  read -r _execution_choice </dev/tty 2>/dev/null || _execution_choice=""

  case "$_execution_choice" in
    2)
      "$NEXUS_CONFIG" set execution_mode governed_ccb 2>/dev/null || true
      echo "  selected governed_ccb"
      echo "  next: finish setup, then make sure CCB providers are mounted for this repo"
      echo "  standard start: tmux && ccb codex gemini claude"
      ;;
    1)
      "$NEXUS_CONFIG" set execution_mode local_provider 2>/dev/null || true
      "$NEXUS_CONFIG" set primary_provider claude 2>/dev/null || true
      echo "  selected local_provider (claude)"
      echo "  next: you can keep using the current Claude session"
      ;;
    *)
      echo "Error: explicit execution-mode choice required when CCB is detected. Re-run ./setup and choose 1 or 2." >&2
      return 1
      ;;
  esac
}

supports_local_claude_subagents() {
  command -v claude >/dev/null 2>&1 || return 1

  if ! _claude_help="$(claude --help 2>&1)"; then
    return 1
  fi
  printf '%s' "$_claude_help" | grep -q -- '--agents' || return 1
  printf '%s' "$_claude_help" | grep -q -- '--agent' || return 1
}

version_at_least() {
  _current="$1"
  _required="$2"
  awk -v current="$_current" -v required="$_required" '
    function split_version(value, parts) {
      split(value, parts, ".")
      for (i = 1; i <= 3; i++) {
        parts[i] = parts[i] == "" ? 0 : parts[i] + 0
      }
    }
    BEGIN {
      split_version(current, c)
      split_version(required, r)
      for (i = 1; i <= 3; i++) {
        if (c[i] > r[i]) exit 0
        if (c[i] < r[i]) exit 1
      }
      exit 0
    }
  '
}

claude_agent_teams_enabled() {
  [ "${CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS:-}" = "1" ] && return 0
  [ -f "$HOME/.claude/settings.json" ] || return 1
  grep -Eq '"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS"[[:space:]]*:[[:space:]]*"1"' "$HOME/.claude/settings.json" 2>/dev/null
}

supports_local_claude_agent_team() {
  command -v claude >/dev/null 2>&1 || return 1

  _claude_version_output="$(claude --version 2>/dev/null || true)"
  _claude_version="$(printf '%s\n' "$_claude_version_output" | sed -E 's/^([0-9]+[.][0-9]+[.][0-9]+).*/\1/' | head -1)"
  [ -n "$_claude_version" ] || return 1
  version_at_least "$_claude_version" "2.1.32" || return 1
  claude_agent_teams_enabled || return 1
}

supports_local_codex_multi_session() {
  command -v codex >/dev/null 2>&1 || return 1

  if ! _codex_help="$(codex --help 2>&1)"; then
    return 1
  fi
  printf '%s' "$_codex_help" | grep -q -- 'exec' || return 1
  printf '%s' "$_codex_help" | grep -q -- 'resume' || return 1
}

maybe_offer_local_topology_choice() {
  [ "$INSTALL_CLAUDE" -eq 1 ] || [ "$INSTALL_CODEX" -eq 1 ] || return 0
  [ -t 0 ] || return 0

  _mode="$("$NEXUS_CONFIG" get execution_mode 2>/dev/null || true)"
  if [ -z "$_mode" ]; then
    if [ "$HOST" = "codex" ] || { [ "$INSTALL_CODEX" -eq 1 ] && [ "$INSTALL_CLAUDE" -eq 0 ]; }; then
      _mode="local_provider"
      "$NEXUS_CONFIG" set execution_mode local_provider 2>/dev/null || true
    elif ask_available; then
      _mode="governed_ccb"
    else
      _mode="local_provider"
    fi
  fi
  [ "$_mode" = "local_provider" ] || return 0

  _provider="$("$NEXUS_CONFIG" get primary_provider 2>/dev/null || true)"
  if [ -z "$_provider" ]; then
    if [ "$HOST" = "codex" ]; then
      _provider="codex"
    elif [ "$HOST" = "claude" ]; then
      _provider="claude"
    elif [ "$INSTALL_CODEX" -eq 1 ] && [ "$INSTALL_CLAUDE" -eq 0 ]; then
      _provider="codex"
    else
      _provider="claude"
    fi
    "$NEXUS_CONFIG" set primary_provider "$_provider" 2>/dev/null || true
  fi
  [ "$_provider" = "claude" ] || [ "$_provider" = "codex" ] || return 0

  _topology="$("$NEXUS_CONFIG" get provider_topology 2>/dev/null || true)"
  [ -n "$_topology" ] && return 0

  if [ "$_provider" = "claude" ] && ! supports_local_claude_subagents; then
    "$NEXUS_CONFIG" set provider_topology single_agent 2>/dev/null || true
    echo ""
    echo "Local Claude topology: subagents are unavailable with the installed claude CLI."
    echo "  selected local_provider (claude, single_agent)"
    return 0
  fi

  echo ""
  if [ "$_provider" = "codex" ]; then
    echo "Local Codex topology: how should Nexus run without CCB?"
  else
    echo "Local Claude topology: how should Nexus run without CCB?"
  fi
  echo ""
  echo "  1) single_agent"
  if [ "$_provider" = "codex" ]; then
    echo "     One Codex local execution path. Lowest friction."
  else
    echo "     One Claude local execution path. Lowest friction."
  fi
  echo ""
  echo "  2) subagents"
  if [ "$_provider" = "codex" ]; then
    echo "     Codex role-specific local passes for build, review, and QA."
    if supports_local_codex_multi_session; then
      echo ""
      echo "  3) multi_session"
      echo "     Codex independent local sessions for build, review, and QA."
    fi
  else
    echo "     Claude local subagents for build, review, and QA."
    if supports_local_claude_agent_team; then
      echo ""
      echo "  3) agent_team"
      echo "     Claude Code Agent Teams for review, investigation, planning, and release-gate passes."
    else
      echo ""
      echo "     agent_team unavailable: requires Claude Code >= 2.1.32 and CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1."
    fi
  fi
  echo ""
  if [ "$_provider" = "codex" ] && supports_local_codex_multi_session; then
    printf "Choice [1/2/3] (default: 1, auto-selects in 10s): "
  elif [ "$_provider" = "claude" ] && supports_local_claude_agent_team; then
    printf "Choice [1/2/3] (default: 1, auto-selects in 10s): "
  else
    printf "Choice [1/2] (default: 1, auto-selects in 10s): "
  fi
  read -t 10 -r _topology_choice </dev/tty 2>/dev/null || _topology_choice=""

  case "$_topology_choice" in
    3)
      if [ "$_provider" = "codex" ]; then
        "$NEXUS_CONFIG" set provider_topology multi_session 2>/dev/null || true
        echo "  selected local_provider (codex, multi_session)"
      elif supports_local_claude_agent_team; then
        "$NEXUS_CONFIG" set provider_topology agent_team 2>/dev/null || true
        echo "  selected local_provider (claude, agent_team)"
      else
        "$NEXUS_CONFIG" set provider_topology single_agent 2>/dev/null || true
        echo "  selected local_provider (claude, single_agent)"
      fi
      ;;
    2)
      "$NEXUS_CONFIG" set provider_topology subagents 2>/dev/null || true
      if [ "$_provider" = "codex" ]; then
        echo "  selected local_provider (codex, subagents)"
      else
        echo "  selected local_provider (claude, subagents)"
      fi
      ;;
    *)
      "$NEXUS_CONFIG" set provider_topology single_agent 2>/dev/null || true
      if [ "$_provider" = "codex" ]; then
        echo "  selected local_provider (codex, single_agent)"
      else
        echo "  selected local_provider (claude, single_agent)"
      fi
      ;;
  esac
}

announce_execution_mode() {
  [ -x "$NEXUS_CONFIG" ] || return 0

  _effective="$("$NEXUS_CONFIG" effective-execution 2>/dev/null || true)"
  [ -n "$_effective" ] || return 0

  _field() {
    printf '%s\n' "$_effective" | sed -n "s/^$1: //p" | head -1
  }

  _mode="$(_field execution_mode)"
  _mode_configured="$(_field execution_mode_configured)"
  _provider="$(_field effective_primary_provider)"
  _topology="$(_field effective_provider_topology)"
  _path="$(_field effective_requested_execution_path)"
  _session_ready="$(_field current_session_ready)"

  if [ "$_mode_configured" = "yes" ]; then
    echo "  execution mode: ${_mode} (saved preference)"
  else
    echo "  execution mode: ${_mode} (default from machine state)"
  fi
  echo "  execution path: ${_path}"
  echo "  current session ready: ${_session_ready}"

  if [ "$_mode" = "governed_ccb" ]; then
    _ccb_available="$(_field ccb_available)"
    _governed_ready="$(_field governed_ready)"
    _mounted="$(_field mounted_providers)"
    _missing="$(_field missing_providers)"

    echo "  ccb available: ${_ccb_available}"
    echo "  governed ready: ${_governed_ready}"
    echo "  mounted providers: ${_mounted}"
    echo "  missing providers: ${_missing}"

    if [ "$_governed_ready" = "yes" ]; then
      echo "  next: continue from a CCB-managed Claude session in this repo"
    else
      echo "  next: mount the missing providers, usually via tmux + 'ccb codex gemini claude'"
    fi
    return 0
  fi

  _provider_cli="$(_field provider_cli_available)"
  echo "  provider CLI available: ${_provider_cli}"
  if [ "$_provider_cli" = "yes" ]; then
    echo "  next: continue in the current ${_provider} session with ${_topology}"
  else
    echo "  note: /handoff will block until ${_provider} is installed or execution_mode is switched to governed_ccb"
  fi
}

# --local: install to .claude/skills/ in the current working directory
if [ "$LOCAL_INSTALL" -eq 1 ]; then
  if [ "$HOST" != "claude" ]; then
    echo "Error: --local is only supported for Claude Code (not $HOST)." >&2
    exit 1
  fi
  INSTALL_SKILLS_DIR="$(pwd)/.claude/skills"
  mkdir -p "$INSTALL_SKILLS_DIR"
  HOST="claude"
  INSTALL_CODEX=0
fi

# For auto: detect which agents are installed
INSTALL_CLAUDE=0
INSTALL_CODEX=0
INSTALL_GEMINI=0
INSTALL_KIRO=0
INSTALL_FACTORY=0
if [ "$HOST" = "auto" ]; then
  command -v claude >/dev/null 2>&1 && INSTALL_CLAUDE=1
  command -v codex >/dev/null 2>&1 && INSTALL_CODEX=1
  command -v gemini >/dev/null 2>&1 && INSTALL_GEMINI=1
  command -v kiro-cli >/dev/null 2>&1 && INSTALL_KIRO=1
  command -v droid >/dev/null 2>&1 && INSTALL_FACTORY=1
  # If none found, default to claude
  if [ "$INSTALL_CLAUDE" -eq 0 ] && [ "$INSTALL_CODEX" -eq 0 ] && [ "$INSTALL_GEMINI" -eq 0 ] && [ "$INSTALL_KIRO" -eq 0 ] && [ "$INSTALL_FACTORY" -eq 0 ]; then
    INSTALL_CLAUDE=1
  fi
elif [ "$HOST" = "claude" ]; then
  INSTALL_CLAUDE=1
elif [ "$HOST" = "codex" ]; then
  INSTALL_CODEX=1
elif [ "$HOST" = "gemini-cli" ] || [ "$HOST" = "gemini" ]; then
  INSTALL_GEMINI=1
elif [ "$HOST" = "kiro" ]; then
  INSTALL_KIRO=1
elif [ "$HOST" = "factory" ]; then
  INSTALL_FACTORY=1
fi

migrate_direct_codex_install() {
  local nexus_dir="$1"
  local codex_nexus="$2"
  local migrated_dir="$HOME/.nexus/repos/nexus"

  [ "$nexus_dir" = "$codex_nexus" ] || return 0
  [ -L "$nexus_dir" ] && return 0

  mkdir -p "$(dirname "$migrated_dir")"
  if [ -e "$migrated_dir" ] && [ "$migrated_dir" != "$nexus_dir" ]; then
    echo "nexus setup failed: direct Codex install detected at $nexus_dir" >&2
    echo "A migrated repo already exists at $migrated_dir; move one of them aside and rerun setup." >&2
    exit 1
  fi

  echo "Migrating direct Codex install to $migrated_dir to avoid duplicate skill discovery..."
  mv "$nexus_dir" "$migrated_dir"
  SOURCE_NEXUS_DIR="$migrated_dir"
  INSTALL_NEXUS_DIR="$migrated_dir"
  INSTALL_SKILLS_DIR="$(dirname "$INSTALL_NEXUS_DIR")"
  BROWSE_BIN="$SOURCE_NEXUS_DIR/runtimes/browse/dist/browse"
}

if [ "$INSTALL_CODEX" -eq 1 ]; then
  migrate_direct_codex_install "$SOURCE_NEXUS_DIR" "$CODEX_NEXUS"
fi

ensure_playwright_browser() {
  if [ "$IS_WINDOWS" -eq 1 ]; then
    # On Windows, Bun can't launch Chromium due to broken pipe handling
    # (oven-sh/bun#4253). Use Node.js to verify Chromium works instead.
    (
      cd "$SOURCE_NEXUS_DIR"
      node -e "const { chromium } = require('playwright'); (async () => { const b = await chromium.launch(); await b.close(); })()" 2>/dev/null
    )
  else
    (
      cd "$SOURCE_NEXUS_DIR"
      bun --eval 'import { chromium } from "playwright"; const browser = await chromium.launch(); await browser.close();'
    ) >/dev/null 2>&1
  fi
}

run_design_runtime_doctor() {
  [ -x "$DESIGN_BIN" ] || return 0
  echo "Checking design runtime..."
  if ! "$DESIGN_BIN" doctor; then
    echo "  warning: design runtime doctor failed unexpectedly" >&2
  fi
}

# 1. Build browse binary if needed (smart rebuild: stale sources, package.json, lock)
NEEDS_BUILD=0
if [ ! -x "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -n "$(find "$SOURCE_NEXUS_DIR/runtimes/browse/src" -type f -newer "$BROWSE_BIN" -print -quit 2>/dev/null)" ]; then
  NEEDS_BUILD=1
elif [ "$SOURCE_NEXUS_DIR/package.json" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -f "$SOURCE_NEXUS_DIR/bun.lock" ] && [ "$SOURCE_NEXUS_DIR/bun.lock" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
fi

if [ "$NEEDS_BUILD" -eq 1 ]; then
  echo "Building browse binary..."
  (
    cd "$SOURCE_NEXUS_DIR"
    bun install
    bun run build
  )
  # Safety net: write .version if build script didn't (e.g., git not available during build)
  if [ ! -f "$SOURCE_NEXUS_DIR/runtimes/browse/dist/.version" ]; then
    git -C "$SOURCE_NEXUS_DIR" rev-parse HEAD > "$SOURCE_NEXUS_DIR/runtimes/browse/dist/.version" 2>/dev/null || true
  fi
fi

if [ ! -x "$BROWSE_BIN" ]; then
  echo "nexus setup failed: browse binary missing at $BROWSE_BIN" >&2
  exit 1
fi

# 1b. Generate .agents/ Codex skill docs — always regenerate to prevent stale descriptions.
# .agents/ is no longer committed — generated at setup time from .tmpl templates.
# bun run build already does this, but we need it when NEEDS_BUILD=0 (binary is fresh).
# Always regenerate: generation is fast (<2s) and mtime-based staleness checks are fragile
# (miss stale files when timestamps match after clone/checkout/upgrade).
AGENTS_DIR="$SOURCE_NEXUS_DIR/.agents/skills"
NEEDS_AGENTS_GEN=1

if [ "$NEEDS_AGENTS_GEN" -eq 1 ] && [ "$NEEDS_BUILD" -eq 0 ]; then
  echo "Generating .agents/ skill docs..."
  (
    cd "$SOURCE_NEXUS_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run gen:skill-docs --host codex
  )
fi

# 1c. Generate .factory/ Factory Droid skill docs
if [ "$INSTALL_FACTORY" -eq 1 ] && [ "$NEEDS_BUILD" -eq 0 ]; then
  echo "Generating .factory/ skill docs..."
  (
    cd "$SOURCE_NEXUS_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run gen:skill-docs --host factory
  )
fi

# 1d. Generate .gemini/ Gemini CLI skill docs
if [ "$INSTALL_GEMINI" -eq 1 ] && [ "$NEEDS_BUILD" -eq 0 ]; then
  echo "Generating .gemini/ skill docs..."
  (
    cd "$SOURCE_NEXUS_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run gen:skill-docs --host gemini-cli
  )
fi

# 2. Ensure Playwright's Chromium is available
if ! ensure_playwright_browser; then
  echo "Installing Playwright Chromium..."
  (
    cd "$SOURCE_NEXUS_DIR"
    bunx playwright install chromium
  )

  if [ "$IS_WINDOWS" -eq 1 ]; then
    # On Windows, Node.js launches Chromium (not Bun — see oven-sh/bun#4253).
    # Ensure playwright is importable by Node from the Nexus directory.
    if ! command -v node >/dev/null 2>&1; then
      echo "nexus setup failed: Node.js is required on Windows (Bun cannot launch Chromium due to a pipe bug)" >&2
      echo "  Install Node.js: https://nodejs.org/" >&2
      exit 1
    fi
    echo "Windows detected — verifying Node.js can load Playwright..."
    (
      cd "$SOURCE_NEXUS_DIR"
      # Bun's node_modules already has playwright; verify Node can require it
      node -e "require('playwright')" 2>/dev/null || npm install --no-save playwright
    )
  fi
fi

if ! ensure_playwright_browser; then
  if [ "$IS_WINDOWS" -eq 1 ]; then
    echo "nexus setup failed: Playwright Chromium could not be launched via Node.js" >&2
    echo "  This is a known issue with Bun on Windows (oven-sh/bun#4253)." >&2
    echo "  Ensure Node.js is installed and 'node -e \"require('playwright')\"' works." >&2
  else
    echo "nexus setup failed: Playwright Chromium could not be launched" >&2
  fi
  exit 1
fi

run_design_runtime_doctor

# 3. Ensure ~/.nexus global state directory exists
NEXUS_STATE_DIR="$HOME/.nexus"
mkdir -p "$NEXUS_STATE_DIR/projects"

# ─── Helper: link Claude skill subdirectories into a skills parent directory ──
# When SKILL_PREFIX=1, symlinks are prefixed with "nexus-" to make Nexus the
# visible namespace owner (e.g., nexus-review instead of review).
# Use --no-prefix to restore the old flat names.
find_claude_skill_files() {
  local nexus_dir="$1"
  find "$nexus_dir" \
    \( -path "$nexus_dir/.git" -o \
       -path "$nexus_dir/.github" -o \
       -path "$nexus_dir/.agents" -o \
       -path "$nexus_dir/.factory" -o \
       -path "$nexus_dir/.gemini" -o \
       -path "$nexus_dir/node_modules" -o \
       -path "$nexus_dir/dist" -o \
       -path "$nexus_dir/upstream" \) -prune -o \
    -type f -name SKILL.md -print
}

skill_name_from_skill_file() {
  local skill_file="$1"
  local fallback="$2"
  local name
  name=$(grep -m1 '^name:' "$skill_file" 2>/dev/null | sed 's/^name:[[:space:]]*//' | tr -d '[:space:]' || true)
  [ -n "$name" ] && echo "$name" || echo "$fallback"
}

is_inherently_prefixed_skill() {
  case "$1" in
    nexus-upgrade) return 0 ;;
    *) return 1 ;;
  esac
}

link_claude_skill_dirs() {
  local nexus_dir="$1"
  local skills_dir="$2"
  local linked=()
  while IFS= read -r skill_file; do
    skill_dir="$(dirname "$skill_file")"
    [ "$skill_dir" = "$nexus_dir" ] && continue
    rel_dir="${skill_dir#$nexus_dir/}"
    # Use frontmatter name: if present (e.g., run-tests/ with name: test → symlink as "test")
    skill_name=$(skill_name_from_skill_file "$skill_file" "$(basename "$skill_dir")")
    # Apply nexus- prefix unless --no-prefix or already inherently prefixed
    if [ "$SKILL_PREFIX" -eq 1 ]; then
      case "$skill_name" in
        nexus-*) link_name="$skill_name" ;;
        *)       link_name="nexus-$skill_name" ;;
      esac
    else
      if is_inherently_prefixed_skill "$skill_name"; then
        link_name="$skill_name"
      else
        link_name="${skill_name#nexus-}"
      fi
    fi
    target="$skills_dir/$link_name"
    # Create or update symlink; skip if a real file/directory exists
    if [ -L "$target" ] || [ ! -e "$target" ]; then
      ln -snf "nexus/$rel_dir" "$target"
      linked+=("$link_name")
    fi
    if [ "$SKILL_PREFIX" -eq 1 ]; then
      old_name="${skill_name#nexus-}"
      if ! is_inherently_prefixed_skill "$skill_name"; then
        [ -L "$skills_dir/$old_name" ] && rm -f "$skills_dir/$old_name"
      fi
    fi
  done < <(find_claude_skill_files "$nexus_dir")
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

quarantine_canonical_skill_conflicts() {
  local skills_dir="$1"
  local label="${2:-skills}"
  local backup_root="$HOME/.nexus/nexus-conflicts/$(date +%Y%m%d%H%M%S)-$$/$label"
  local moved=()

  for skill_name in discover frame plan handoff build review qa ship closeout; do
    target="$skills_dir/$skill_name"
    [ -e "$target" ] || continue
    [ -L "$target" ] && continue

    mkdir -p "$backup_root"
    backup_target="$backup_root/$skill_name"
    if [ -e "$backup_target" ]; then
      backup_target="$backup_root/${skill_name}.$(date +%s).$$"
    fi
    mv "$target" "$backup_target"
    moved+=("$skill_name")
  done

  if [ ${#moved[@]} -gt 0 ]; then
    echo "  quarantined conflicting canonical skills in $skills_dir: ${moved[*]}"
    echo "  conflict backup: $backup_root"
  fi
}

quarantine_claude_canonical_skill_conflicts() {
  quarantine_canonical_skill_conflicts "$1" "claude"
}

quarantine_global_agents_canonical_skill_conflicts() {
  [ -d "$1" ] || return 0
  quarantine_canonical_skill_conflicts "$1" "agents"
}

# ─── Helper: remove old unprefixed Claude skill symlinks ──────────────────────
# Migration: when switching from flat names to nexus- prefixed names,
# clean up stale symlinks that point into the Nexus runtime directory.
cleanup_old_claude_symlinks() {
  local nexus_dir="$1"
  local skills_dir="$2"
  local removed=()
  while IFS= read -r skill_file; do
    skill_dir="$(dirname "$skill_file")"
    [ "$skill_dir" = "$nexus_dir" ] && continue
    skill_name=$(skill_name_from_skill_file "$skill_file" "$(basename "$skill_dir")")
    is_inherently_prefixed_skill "$skill_name" && continue
    old_name="${skill_name#nexus-}"
    old_target="$skills_dir/$old_name"
    # Only remove if it's a symlink pointing into nexus/
    if [ -L "$old_target" ]; then
      link_dest="$(readlink "$old_target" 2>/dev/null || true)"
      case "$link_dest" in
        nexus/*|*/nexus/*)
          rm -f "$old_target"
          removed+=("$old_name")
          ;;
      esac
    fi
  done < <(find_claude_skill_files "$nexus_dir")
  if [ ${#removed[@]} -gt 0 ]; then
    echo "  cleaned up old symlinks: ${removed[*]}"
  fi
}

# ─── Helper: remove old prefixed Claude skill symlinks ────────────────────────
# Reverse migration: when switching from prefixed names to flat names,
# clean up stale nexus-* symlinks that point into the Nexus runtime directory.
cleanup_prefixed_claude_symlinks() {
  local nexus_dir="$1"
  local skills_dir="$2"
  local removed=()
  while IFS= read -r skill_file; do
    skill_dir="$(dirname "$skill_file")"
    [ "$skill_dir" = "$nexus_dir" ] && continue
    skill_name=$(skill_name_from_skill_file "$skill_file" "$(basename "$skill_dir")")
    is_inherently_prefixed_skill "$skill_name" && continue
    flat_name="${skill_name#nexus-}"
    prefixed_target="$skills_dir/nexus-$flat_name"
    if [ -L "$prefixed_target" ]; then
      link_dest="$(readlink "$prefixed_target" 2>/dev/null || true)"
      case "$link_dest" in
        nexus/*|*/nexus/*)
          rm -f "$prefixed_target"
          removed+=("$(basename "$prefixed_target")")
          ;;
      esac
    fi
  done < <(find_claude_skill_files "$nexus_dir")
  if [ ${#removed[@]} -gt 0 ]; then
    echo "  cleaned up prefixed symlinks: ${removed[*]}"
  fi
}

# ─── Helper: link generated Codex skills into a skills parent directory ──
# Installs from .agents/skills/nexus-* (the generated Codex-format skills)
# instead of source dirs (which have Claude paths).
link_codex_skill_dirs() {
  local nexus_dir="$1"
  local skills_dir="$2"
  local agents_dir="$nexus_dir/.agents/skills"
  local linked=()

  if [ ! -d "$agents_dir" ]; then
    echo "  Generating .agents/ skill docs..."
    ( cd "$nexus_dir" && bun run gen:skill-docs --host codex )
  fi

  if [ ! -d "$agents_dir" ]; then
    echo "  warning: .agents/skills/ generation failed — run 'bun run gen:skill-docs --host codex' manually" >&2
    return 1
  fi

  for skill_dir in "$agents_dir"/nexus*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      # Skip the sidecar directory — it contains runtime asset symlinks (bin/,
      # browse/), not a skill. Linking it would overwrite the root nexus
      # symlink that Step 5 already pointed at the repo root.
      [ "$skill_name" = "nexus" ] && continue
      target="$skills_dir/$skill_name"
      # Create or update symlink
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "$skill_dir" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

# ─── Helper: runtime/reference compatibility assets ─────────────────────
# Source assets may move under taxonomy roots, but installed skills must keep
# resolving historical $NEXUS_ROOT/... paths.
link_compat_asset() {
  local repo_root="$1"
  local runtime_root="$2"
  local compat_rel="$3"
  local future_rel="$4"
  local current_rel="$5"
  local src=""

  if [ -e "$repo_root/$future_rel" ]; then
    src="$repo_root/$future_rel"
  elif [ -e "$repo_root/$current_rel" ]; then
    src="$repo_root/$current_rel"
  else
    return 0
  fi

  local dst="$runtime_root/$compat_rel"
  mkdir -p "$(dirname "$dst")"
  if [ -L "$dst" ] || [ ! -e "$dst" ]; then
    ln -snf "$src" "$dst"
  fi
}

link_reference_compat_assets() {
  local repo_root="$1"
  local runtime_root="$2"

  link_compat_asset "$repo_root" "$runtime_root" "review/checklist.md" "references/review/checklist.md" "review/checklist.md"
  link_compat_asset "$repo_root" "$runtime_root" "review/design-checklist.md" "references/review/design-checklist.md" "review/design-checklist.md"
  link_compat_asset "$repo_root" "$runtime_root" "review/greptile-triage.md" "references/review/greptile-triage.md" "review/greptile-triage.md"
  link_compat_asset "$repo_root" "$runtime_root" "review/TODOS-format.md" "references/review/TODOS-format.md" "review/TODOS-format.md"
  link_compat_asset "$repo_root" "$runtime_root" "review/specialists" "references/review/specialists" "review/specialists"
  link_compat_asset "$repo_root" "$runtime_root" "qa/templates" "references/qa/templates" "qa/templates"
  link_compat_asset "$repo_root" "$runtime_root" "qa/references" "references/qa/references" "qa/references"
  link_compat_asset "$repo_root" "$runtime_root" "design/references" "references/design" "design/references"
  link_compat_asset "$repo_root" "$runtime_root" "cso/ACKNOWLEDGEMENTS.md" "references/cso/ACKNOWLEDGEMENTS.md" "cso/ACKNOWLEDGEMENTS.md"
}

link_runtime_compat_assets() {
  local repo_root="$1"
  local runtime_root="$2"

  link_compat_asset "$repo_root" "$runtime_root" "extension" "runtimes/browse/extension" "extension"
  link_compat_asset "$repo_root" "$runtime_root" "browse/dist" "runtimes/browse/dist" "browse/dist"
  link_compat_asset "$repo_root" "$runtime_root" "browse/bin" "runtimes/browse/bin" "browse/bin"
  link_compat_asset "$repo_root" "$runtime_root" "design/dist" "runtimes/design/dist" "design/dist"
  link_compat_asset "$repo_root" "$runtime_root" "design-html/vendor" "runtimes/design-html/vendor" "design-html/vendor"
  link_compat_asset "$repo_root" "$runtime_root" "careful/bin" "runtimes/safety/careful/bin" "careful/bin"
  link_compat_asset "$repo_root" "$runtime_root" "freeze/bin" "runtimes/safety/freeze/bin" "freeze/bin"
}

# ─── Helper: create .agents/skills/nexus/ sidecar symlinks ──────────
# Codex/Gemini/Cursor read skills from .agents/skills/. We link runtime
# assets (bin/, browse/dist/, extension/, review/, qa/, etc.) so skill templates can
# resolve paths like $SKILL_ROOT/review/design-checklist.md.
create_agents_sidecar() {
  local repo_root="$1"
  local agents_nexus="$repo_root/.agents/skills/nexus"

  for legacy_parent in browse design extension review qa cso; do
    if [ -L "$agents_nexus/$legacy_parent" ]; then
      rm -f "$agents_nexus/$legacy_parent"
    fi
  done

  mkdir -p "$agents_nexus" "$agents_nexus/browse" "$agents_nexus/design"

  # Sidecar directories that skills reference at runtime
  if [ -d "$repo_root/bin" ]; then
    ln -snf "$repo_root/bin" "$agents_nexus/bin"
  fi
  link_runtime_compat_assets "$repo_root" "$agents_nexus"
  link_reference_compat_assets "$repo_root" "$agents_nexus"

  # Sidecar files that skills reference at runtime
  for file in ETHOS.md; do
    local src="$SOURCE_NEXUS_DIR/$file"
    local dst="$agents_nexus/$file"
    if [ -f "$src" ]; then
      if [ -L "$dst" ] || [ ! -e "$dst" ]; then
        ln -snf "$src" "$dst"
      fi
    fi
  done
}

# ─── Helper: create a minimal ~/.codex/skills/nexus runtime root ───────────
# Codex scans ~/.codex/skills recursively. Exposing the whole repo here causes
# duplicate skills because source SKILL.md files and generated Codex skills are
# both discoverable. Keep this directory limited to runtime assets + root skill.
create_codex_runtime_root() {
  local nexus_dir="$1"
  local codex_nexus="$2"
  local agents_dir="$nexus_dir/.agents/skills"

  if [ -L "$codex_nexus" ]; then
    rm -f "$codex_nexus"
  elif [ -d "$codex_nexus" ] && [ "$codex_nexus" != "$nexus_dir" ]; then
    # Old direct installs left a real directory here with stale source skills.
    # Remove it so we start fresh with only the minimal runtime assets.
    rm -rf "$codex_nexus"
  fi

  mkdir -p "$codex_nexus" "$codex_nexus/browse" "$codex_nexus/design" "$codex_nexus/nexus-upgrade" "$codex_nexus/review"

  if [ -f "$agents_dir/nexus/SKILL.md" ]; then
    ln -snf "$agents_dir/nexus/SKILL.md" "$codex_nexus/SKILL.md"
  fi
  if [ -d "$nexus_dir/bin" ]; then
    ln -snf "$nexus_dir/bin" "$codex_nexus/bin"
  fi
  if [ -f "$agents_dir/nexus-upgrade/SKILL.md" ]; then
    ln -snf "$agents_dir/nexus-upgrade/SKILL.md" "$codex_nexus/nexus-upgrade/SKILL.md"
  fi
  link_runtime_compat_assets "$nexus_dir" "$codex_nexus"
  link_reference_compat_assets "$nexus_dir" "$codex_nexus"
  # ETHOS.md — referenced by "Search Before Building" in all skill preambles
  if [ -f "$nexus_dir/ETHOS.md" ]; then
    ln -snf "$nexus_dir/ETHOS.md" "$codex_nexus/ETHOS.md"
  fi
}

create_factory_runtime_root() {
  local nexus_dir="$1"
  local factory_nexus="$2"
  local factory_dir="$nexus_dir/.factory/skills"

  if [ -L "$factory_nexus" ]; then
    rm -f "$factory_nexus"
  elif [ -d "$factory_nexus" ] && [ "$factory_nexus" != "$nexus_dir" ]; then
    rm -rf "$factory_nexus"
  fi

  mkdir -p "$factory_nexus" "$factory_nexus/browse" "$factory_nexus/design" "$factory_nexus/nexus-upgrade" "$factory_nexus/review"

  if [ -f "$factory_dir/nexus/SKILL.md" ]; then
    ln -snf "$factory_dir/nexus/SKILL.md" "$factory_nexus/SKILL.md"
  fi
  if [ -d "$nexus_dir/bin" ]; then
    ln -snf "$nexus_dir/bin" "$factory_nexus/bin"
  fi
  if [ -f "$factory_dir/nexus-upgrade/SKILL.md" ]; then
    ln -snf "$factory_dir/nexus-upgrade/SKILL.md" "$factory_nexus/nexus-upgrade/SKILL.md"
  fi
  link_runtime_compat_assets "$nexus_dir" "$factory_nexus"
  link_reference_compat_assets "$nexus_dir" "$factory_nexus"
  if [ -f "$nexus_dir/ETHOS.md" ]; then
    ln -snf "$nexus_dir/ETHOS.md" "$factory_nexus/ETHOS.md"
  fi
}

link_factory_skill_dirs() {
  local nexus_dir="$1"
  local skills_dir="$2"
  local factory_dir="$nexus_dir/.factory/skills"
  local linked=()

  if [ ! -d "$factory_dir" ]; then
