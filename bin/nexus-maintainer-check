#!/usr/bin/env bash
# nexus-maintainer-check — derive the current Nexus maintainer report from repo-visible inputs.
#
# Usage:
#   nexus-maintainer-check
#
# Env overrides (for testing):
#   NEXUS_DIR                — override the Nexus repo root
#   NEXUS_GIT_STATUS_LINES   — override git status --short output for release preflight
#   NEXUS_EXISTING_TAGS      — override git tag --list output for release preflight
#   NEXUS_REMOTE_RELEASE_MODE — "skip" to avoid remote release checks for now
set -euo pipefail

case "${1:-}" in
  -h|--help)
    awk '
      NR == 1 { next }
      /^set -euo pipefail$/ { exit }
      /^# / { sub(/^# /, ""); print; next }
      /^#$/ { print ""; next }
    ' "$0"
    exit 0
    ;;
  "")
    ;;
  *)
    echo "Unknown option: ${1}" >&2
    echo "Usage: nexus-maintainer-check" >&2
    exit 1
    ;;
esac

SCRIPT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
NEXUS_DIR="${NEXUS_DIR:-$SCRIPT_ROOT}"
GIT_STATUS_LINES="${NEXUS_GIT_STATUS_LINES:-$(git -C "$NEXUS_DIR" status --short 2>/dev/null || true)}"
EXISTING_TAGS="${NEXUS_EXISTING_TAGS:-$(git -C "$NEXUS_DIR" tag --list 2>/dev/null || true)}"
REMOTE_RELEASE_MODE="${NEXUS_REMOTE_RELEASE_MODE:-skip}"
RELEASE_DIFF_NAMES="${NEXUS_RELEASE_DIFF_NAMES:-}"

CORE_JS="$(cat <<'EOF'
const fs = await import('fs');
const { join } = await import('path');
const maintainerLoop = await import(process.env.NEXUS_MAINTAINER_LOOP_PATH);
const releaseContract = await import(process.env.NEXUS_RELEASE_CONTRACT_PATH);
const releasePublish = await import(process.env.NEXUS_RELEASE_PUBLISH_PATH);
const releaseRemote = await import(process.env.NEXUS_RELEASE_REMOTE_PATH);
const upstreamMaintenance = await import(process.env.NEXUS_UPSTREAM_MAINTENANCE_PATH);

const root = process.env.NEXUS_DIR;
const remoteMode = process.env.NEXUS_REMOTE_RELEASE_MODE ?? 'skip';
const generatedAt = new Date().toISOString();

const lock = upstreamMaintenance.parseUpstreamMaintenanceLock(
  fs.readFileSync(join(root, 'upstream-notes', 'upstream-lock.json'), 'utf8'),
);
upstreamMaintenance.alignUpstreamLockWithContract(lock);

const manifest = JSON.parse(fs.readFileSync(join(root, 'release.json'), 'utf8'));
releaseContract.assertReleaseManifest(manifest);

const preflight = releasePublish.buildReleasePreflightReport({
  rootDir: root,
  gitStatusLines: (process.env.NEXUS_GIT_STATUS_LINES ?? '').split('\n').filter(Boolean),
  existingTags: (process.env.NEXUS_EXISTING_TAGS ?? '').split('\n').filter(Boolean),
});

function readGitDiffNames(tag, paths) {
  if ((process.env.NEXUS_RELEASE_DIFF_NAMES ?? '').trim().length > 0) {
    return process.env.NEXUS_RELEASE_DIFF_NAMES.split('\n').map((line) => line.trim()).filter(Boolean);
  }

  const result = Bun.spawnSync(['git', '-C', root, 'diff', '--name-only', `${tag}..HEAD`, '--', ...paths], {
    stdout: 'pipe',
    stderr: 'pipe',
  });

  if (result.exitCode !== 0) {
    return [];
  }

  return result.stdout.toString().split('\n').map((line) => line.trim()).filter(Boolean);
}

function readTextIfPresent(path) {
  try {
    return fs.readFileSync(path, 'utf8');
  } catch (error) {
    if (error && typeof error === 'object' && 'code' in error && error.code === 'ENOENT') {
      return null;
    }
    throw error;
  }
}

function readExistingReport(path) {
  const text = readTextIfPresent(path);
  if (text === null) {
    return null;
  }

  try {
    return maintainerLoop.validateMaintainerLoopReport(JSON.parse(text));
  } catch {
    return null;
  }
}

function writeTextIfChanged(path, nextText) {
  const existingText = readTextIfPresent(path);
  if (existingText === nextText) {
    return;
  }

  fs.writeFileSync(path, nextText);
}

async function resolveRemoteReleaseState() {
  if (remoteMode === 'skip' || remoteMode === 'unknown') {
    return {
      remoteSmokeStatus: 'unknown',
      publishedReleaseMissing: false,
    };
  }

  if (remoteMode === 'missing') {
    return {
      remoteSmokeStatus: 'unknown',
      publishedReleaseMissing: true,
    };
  }

  if (remoteMode === 'blocked') {
    return {
      remoteSmokeStatus: 'blocked',
      publishedReleaseMissing: false,
    };
  }

  if (remoteMode === 'ready') {
    return {
      remoteSmokeStatus: 'ready',
      publishedReleaseMissing: false,
    };
  }

  const releaseRepo = process.env.NEXUS_RELEASE_REPO ?? 'LaPaGaYo/nexus';
  const expectedNotesBody = fs.readFileSync(join(root, manifest.release_notes_path), 'utf8');

  async function loadGitHubReleaseJson() {
    if ((process.env.NEXUS_GH_RELEASE_JSON ?? '').trim().length > 0) {
      return process.env.NEXUS_GH_RELEASE_JSON;
    }

    const result = Bun.spawnSync(
      ['gh', 'release', 'view', manifest.tag, '--repo', releaseRepo, '--json', 'tagName,body,publishedAt,url,name'],
      {
        stdout: 'pipe',
        stderr: 'pipe',
      },
    );

    if (result.exitCode !== 0) {
      const errorText = result.stderr.toString().trim() || result.stdout.toString().trim();
      if (/not found|404/i.test(errorText)) {
        return null;
      }
      throw new Error(errorText || 'gh release view failed');
    }

    return result.stdout.toString();
  }

  async function loadRemoteReleaseJson() {
    if ((process.env.NEXUS_REMOTE_RELEASE_JSON ?? '').trim().length > 0) {
      return process.env.NEXUS_REMOTE_RELEASE_JSON;
    }

    const releaseJsonUrl = `https://raw.githubusercontent.com/${releaseRepo}/${manifest.tag}/release.json`;
    const response = await fetch(releaseJsonUrl, {
      headers: {
        accept: 'application/json',
        'user-agent': 'nexus-maintainer-check',
      },
    });

    if (response.status === 404) {
      return null;
    }

    if (!response.ok) {
      throw new Error(`failed to fetch ${releaseJsonUrl}: ${response.status} ${response.statusText}`);
    }

    return response.text();
  }

  const ghReleaseJson = await loadGitHubReleaseJson();
  const remoteReleaseJson = await loadRemoteReleaseJson();

  if (ghReleaseJson === null || remoteReleaseJson === null) {
    return {
      remoteSmokeStatus: 'unknown',
      publishedReleaseMissing: true,
    };
  }

  const report = await releaseRemote.buildRemoteReleaseSmokeReport({
    expectedTag: manifest.tag,
    expectedVersion: manifest.version,
    expectedNotesBody,
    ghReleaseJson,
    releaseManifestText: remoteReleaseJson,
  });

  return {
    remoteSmokeStatus: report.status,
    publishedReleaseMissing: false,
  };
}

const driftPaths = [
  'lib/nexus',
  'bin',
  '.agents',
  'scripts',
  'docs/releases',
];
const localReleaseDrift = readGitDiffNames(manifest.tag, driftPaths).length > 0;
const remoteState = await resolveRemoteReleaseState();

const report = maintainerLoop.buildMaintainerLoopReport({
  generatedAt,
  upstreams: maintainerLoop.summarizeUpstreamMaintenance(lock),
  release: maintainerLoop.buildMaintainerReleaseState({
    currentVersion: manifest.version,
    currentTag: manifest.tag,
    preflightStatus: preflight.status,
    remoteSmokeStatus: remoteState.remoteSmokeStatus,
  }),
  local_release_drift: localReleaseDrift,
  published_release_missing: remoteState.publishedReleaseMissing,
});

const reportPath = join(root, 'upstream-notes', 'maintainer-status.json');
const markdownPath = join(root, 'upstream-notes', 'maintainer-status.md');
const existingReport = readExistingReport(reportPath);
const finalReport = existingReport !== null && maintainerLoop.reportsMatchExceptGeneratedAt(existingReport, report)
  ? maintainerLoop.validateMaintainerLoopReport({
      ...report,
      generated_at: existingReport.generated_at,
    })
  : report;

writeTextIfChanged(reportPath, maintainerLoop.serializeMaintainerLoopReport(finalReport));
writeTextIfChanged(markdownPath, maintainerLoop.renderMaintainerLoopMarkdown(finalReport));

console.log(`${finalReport.status.toUpperCase()} ${finalReport.next_action}`);
process.exit(finalReport.status === 'ready' ? 0 : 1);
EOF
)"

NEXUS_DIR="$NEXUS_DIR" \
NEXUS_GIT_STATUS_LINES="$GIT_STATUS_LINES" \
NEXUS_EXISTING_TAGS="$EXISTING_TAGS" \
NEXUS_REMOTE_RELEASE_MODE="$REMOTE_RELEASE_MODE" \
NEXUS_RELEASE_DIFF_NAMES="$RELEASE_DIFF_NAMES" \
NEXUS_MAINTAINER_LOOP_PATH="$SCRIPT_ROOT/lib/nexus/maintainer-loop.ts" \
NEXUS_RELEASE_CONTRACT_PATH="$SCRIPT_ROOT/lib/nexus/release-contract.ts" \
NEXUS_RELEASE_PUBLISH_PATH="$SCRIPT_ROOT/lib/nexus/release-publish.ts" \
NEXUS_RELEASE_REMOTE_PATH="$SCRIPT_ROOT/lib/nexus/release-remote.ts" \
NEXUS_UPSTREAM_MAINTENANCE_PATH="$SCRIPT_ROOT/lib/nexus/upstream-maintenance.ts" \
bun -e "$CORE_JS"
