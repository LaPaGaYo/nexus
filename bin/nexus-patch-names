#!/usr/bin/env bash
# nexus-patch-names — patch name: field in SKILL.md frontmatter for Nexus prefix mode
# Usage: nexus-patch-names <skills-dir> <true|false|1|0>
set -euo pipefail

SKILLS_DIR="$1"
DO_PREFIX="$2"

case "$DO_PREFIX" in true|1) DO_PREFIX=1 ;; *) DO_PREFIX=0 ;; esac

PATCHED=0
while IFS= read -r skill_file; do
  skill_dir="$(dirname "$skill_file")"
  [ "$skill_dir" = "$SKILLS_DIR" ] && continue
  dir_name="$(basename "$skill_dir")"
  [ "$dir_name" = "node_modules" ] && continue
  cur=$(grep -m1 '^name:' "$skill_file" 2>/dev/null | sed 's/^name:[[:space:]]*//' | tr -d '[:space:]' || true)
  [ -z "$cur" ] && continue
  [ "$cur" = "nexus" ] && continue
  if [ "$DO_PREFIX" -eq 1 ]; then
    case "$cur" in
      nexus-*) continue ;;
      *)
        new="nexus-$cur"
        ;;
    esac
  else
    case "$cur" in
      nexus-*) new="${cur#nexus-}" ;;
      *) continue ;;
    esac
  fi
  tmp="$(mktemp "${skill_dir}/SKILL.md.XXXXXX")"
  sed "1,/^---$/s/^name:[[:space:]]*${cur}/name: ${new}/" "$skill_file" > "$tmp" && mv "$tmp" "$skill_file"
  PATCHED=$((PATCHED + 1))
done < <(
  find "$SKILLS_DIR" \
    \( -path "$SKILLS_DIR/.git" -o \
       -path "$SKILLS_DIR/.github" -o \
       -path "$SKILLS_DIR/.agents" -o \
       -path "$SKILLS_DIR/.factory" -o \
       -path "$SKILLS_DIR/node_modules" -o \
       -path "$SKILLS_DIR/dist" -o \
       -path "$SKILLS_DIR/upstream" \) -prune -o \
    -type f -name SKILL.md -print
)
if [ "$PATCHED" -gt 0 ]; then
  echo "  patched name: field in $PATCHED skills"
fi
