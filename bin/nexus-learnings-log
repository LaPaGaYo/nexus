#!/usr/bin/env bash
# nexus-learnings-log — append a learning to the project learnings file
# Usage: nexus-learnings-log '{"skill":"review","type":"pitfall","key":"n-plus-one","insight":"...","confidence":8,"source":"observed"}'
#
# Append-only storage. Duplicates (same key+type) are resolved at read time
# by nexus-learnings-search ("latest winner" per key+type).
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
eval "$("$SCRIPT_DIR/nexus-slug" 2>/dev/null)"
STATE_DIR="${NEXUS_STATE_DIR:-$HOME/.nexus}"
mkdir -p "$STATE_DIR/projects/$SLUG"

INPUT="$1"

# Validate: input must be parseable JSON
if ! printf '%s' "$INPUT" | bun -e "JSON.parse(await Bun.stdin.text())" 2>/dev/null; then
  echo "nexus-learnings-log: invalid JSON, skipping" >&2
  exit 1
fi

# Inject defaults (schema_version, ts, id) if not present.
# schema_version and id are only injected for v2-shaped entries (writer_skill present).
#
# This writer_skill gate is a PERMANENT backward-compat boundary, NOT a
# transitional shim — do not "clean it up" assuming all callers are v2.
# v1-shape callers that intentionally remain (use `skill`, no `writer_skill`):
#   - /learn manual-add path (skills/support/learn/SKILL.md.tmpl)
#   - scripts/resolvers/learnings.ts generated example
#   - any external / third-party caller of this bin
# Their v1 entries are left as-is; the read-time normalizer (lib/nexus/
# learning/normalize.ts) lazily upgrades them to virtual v2 at search time.
# Forcing schema_version:2 onto them would make the read-side assertSchemaV2
# gate reject them as malformed v2 — silent data loss. Keep the gate.
INPUT=$(printf '%s' "$INPUT" | bun -e "
  const j = JSON.parse(await Bun.stdin.text());
  const isV2Shape = typeof j.writer_skill === 'string';
  if (isV2Shape && !j.schema_version) j.schema_version = 2;
  if (!j.ts) j.ts = new Date().toISOString();
  if (isV2Shape && !j.id) {
    const { generateLearningId } = await import('$SCRIPT_ROOT/lib/nexus/learning/id.ts');
    j.id = generateLearningId();
  }
  console.log(JSON.stringify(j));
" 2>/dev/null) || true

echo "$INPUT" >> "$STATE_DIR/projects/$SLUG/learnings.jsonl"
