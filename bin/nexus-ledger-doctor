#!/usr/bin/env bash
# nexus-ledger-doctor — report or safely scrub noncanonical Nexus ledger/audit state.
#
# Usage:
#   nexus-ledger-doctor [--json] [--fix-safe]
#
# Env overrides (for testing):
#   NEXUS_DIR                  — override the repo root to inspect
set -euo pipefail

OUTPUT_MODE="text"
FIX_SAFE="false"

while [ "${1:-}" != "" ]; do
  case "${1}" in
    -h|--help)
      awk '
        NR == 1 { next }
        /^set -euo pipefail$/ { exit }
        /^# / { sub(/^# /, ""); print; next }
        /^#$/ { print ""; next }
      ' "$0"
      exit 0
      ;;
    --json)
      OUTPUT_MODE="json"
      shift
      ;;
    --fix-safe)
      FIX_SAFE="true"
      shift
      ;;
    *)
      echo "Unknown option: ${1}" >&2
      echo "Usage: nexus-ledger-doctor [--json] [--fix-safe]" >&2
      exit 1
      ;;
  esac
done

SCRIPT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
NEXUS_DIR="${NEXUS_DIR:-$SCRIPT_ROOT}"

CORE_JS="$(cat <<'EOF'
const ledgerDoctor = await import(process.env.NEXUS_LEDGER_DOCTOR_PATH);

const outputMode = process.env.NEXUS_LEDGER_DOCTOR_OUTPUT_MODE ?? 'text';
const fixSafe = process.env.NEXUS_LEDGER_DOCTOR_FIX_SAFE === 'true';
const result = fixSafe
  ? ledgerDoctor.applySafeLedgerDoctorFix(process.env.NEXUS_DIR)
  : { report: ledgerDoctor.buildLedgerDoctorReport(process.env.NEXUS_DIR), fixed_paths: [], fixed_issue_codes: [] };
const report = result.report;

if (outputMode === 'json') {
  console.log(JSON.stringify(result, null, 2));
  process.exit(report.status === 'clean' ? 0 : 1);
}

if (report.status === 'clean') {
  if (result.fixed_issue_codes.length > 0) {
    console.log(`FIXED ${result.fixed_issue_codes.join(',')}`);
  }
  console.log('CLEAN none');
  process.exit(0);
}

if (result.fixed_issue_codes.length > 0) {
  console.log(`FIXED ${result.fixed_issue_codes.join(',')}`);
}
console.log(`ACTION_REQUIRED ${report.issues.map((issue) => issue.code).join(',')}`);
for (const issue of report.issues) {
  console.log(`- [${issue.code}] ${issue.message}`);
  for (const evidence of issue.evidence) {
    console.log(`  evidence: ${evidence}`);
  }
}
process.exit(1);
EOF
)"

NEXUS_DIR="$NEXUS_DIR" \
NEXUS_LEDGER_DOCTOR_OUTPUT_MODE="$OUTPUT_MODE" \
NEXUS_LEDGER_DOCTOR_FIX_SAFE="$FIX_SAFE" \
NEXUS_LEDGER_DOCTOR_PATH="$SCRIPT_ROOT/lib/nexus/governance/ledger-doctor.ts" \
bun -e "$CORE_JS"
