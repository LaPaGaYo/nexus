#!/usr/bin/env bash
# nexus-relink — re-create skill symlinks based on skill_prefix config
#
# Usage:
#   nexus-relink
#
# Env overrides (for testing):
#   NEXUS_STATE_DIR    — override the Nexus state directory
#   NEXUS_INSTALL_DIR  — override the current install directory
#   NEXUS_SKILLS_DIR   — override the target skills directory
set -euo pipefail

case "${1:-}" in
  -h|--help)
    awk '
      NR == 1 { next }
      /^set -euo pipefail$/ { exit }
      /^# / { sub(/^# /, ""); print; next }
      /^#$/ { print ""; next }
    ' "$0"
    exit 0
    ;;
  "")
    ;;
  *)
    echo "Unknown option: ${1}" >&2
    echo "Usage: nexus-relink" >&2
    exit 1
    ;;
esac

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
NEXUS_CONFIG="${SCRIPT_DIR}/nexus-config"

INSTALL_DIR="${NEXUS_INSTALL_DIR:-}"
if [ -z "$INSTALL_DIR" ]; then
  if [ -d "$HOME/.claude/skills/nexus" ]; then
    INSTALL_DIR="$HOME/.claude/skills/nexus"
  elif [ -d "${SCRIPT_DIR}/.." ] && [ -f "${SCRIPT_DIR}/../setup" ]; then
    INSTALL_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
  fi
fi

if [ -z "$INSTALL_DIR" ] || [ ! -d "$INSTALL_DIR" ]; then
  echo "Error: Nexus install directory not found." >&2
  echo "Run: cd ~/.claude/skills/nexus && ./setup" >&2
  exit 1
fi

SKILLS_DIR="${NEXUS_SKILLS_DIR:-$(dirname "$INSTALL_DIR")}"
[ -d "$SKILLS_DIR" ] || mkdir -p "$SKILLS_DIR"

PREFIX=$("$NEXUS_CONFIG" get skill_prefix 2>/dev/null || echo "false")

find_claude_skill_files() {
  find "$INSTALL_DIR" \
    \( -path "$INSTALL_DIR/.git" -o \
       -path "$INSTALL_DIR/.github" -o \
       -path "$INSTALL_DIR/.agents" -o \
       -path "$INSTALL_DIR/.factory" -o \
       -path "$INSTALL_DIR/node_modules" -o \
       -path "$INSTALL_DIR/dist" -o \
       -path "$INSTALL_DIR/upstream" \) -prune -o \
    -type f -name SKILL.md -print
}

skill_name_from_file() {
  local skill_file="$1"
  local fallback="$2"
  local name
  name=$(grep -m1 '^name:' "$skill_file" 2>/dev/null | sed 's/^name:[[:space:]]*//' | tr -d '[:space:]' || true)
  [ -n "$name" ] && echo "$name" || echo "$fallback"
}

is_inherently_prefixed_skill() {
  case "$1" in
    nexus-upgrade) return 0 ;;
    *) return 1 ;;
  esac
}

SKILL_COUNT=0
while IFS= read -r skill_file; do
  skill_dir="$(dirname "$skill_file")"
  [ "$skill_dir" = "$INSTALL_DIR" ] && continue
  rel_dir="${skill_dir#$INSTALL_DIR/}"
  skill=$(skill_name_from_file "$skill_file" "$(basename "$skill_dir")")

  if [ "$PREFIX" = "true" ]; then
    case "$skill" in
      nexus-*) link_name="$skill" ;;
      *) link_name="nexus-$skill" ;;
    esac
    ln -sfn "$INSTALL_DIR/$rel_dir" "$SKILLS_DIR/$link_name"
    [ "$link_name" != "$skill" ] && [ -L "$SKILLS_DIR/$skill" ] && rm -f "$SKILLS_DIR/$skill"
  else
    if is_inherently_prefixed_skill "$skill"; then
      link_name="$skill"
    else
      link_name="${skill#nexus-}"
    fi
    ln -sfn "$INSTALL_DIR/$rel_dir" "$SKILLS_DIR/$link_name"
    [ "$link_name" != "$skill" ] && [ -L "$SKILLS_DIR/$skill" ] && rm -f "$SKILLS_DIR/$skill"
    [ -L "$SKILLS_DIR/nexus-$link_name" ] && [ "$link_name" != "nexus-$link_name" ] && rm -f "$SKILLS_DIR/nexus-$link_name"
  fi
  SKILL_COUNT=$((SKILL_COUNT + 1))
done < <(find_claude_skill_files)

"$INSTALL_DIR/bin/nexus-patch-names" "$INSTALL_DIR" "$PREFIX"

if [ "$PREFIX" = "true" ]; then
  echo "Relinked $SKILL_COUNT skills as nexus-*"
else
  echo "Relinked $SKILL_COUNT skills as flat names"
fi
