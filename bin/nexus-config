#!/usr/bin/env bash
# nexus-config — read/write Nexus host config
#
# Usage:
#   nexus-config get <key>          — read a config value
#   nexus-config set <key> <value>  — write a config value
#   nexus-config effective-execution — show the effective execution route
#   nexus-config list               — show all config
#
# Env override:
#   NEXUS_STATE_DIR   — override the Nexus host state directory
set -euo pipefail

STATE_DIR="${NEXUS_STATE_DIR:-$HOME/.nexus}"
mkdir -p "$STATE_DIR"
CONFIG_FILE="$STATE_DIR/config.yaml"

CONFIG_HEADER='# Nexus configuration (stored in the active Nexus host state root) — edit freely,
# changes take effect on next skill run.
#
# ─── Behavior ────────────────────────────────────────────────────────
# proactive: true           # Auto-invoke skills when your request matches one.
#                           # Set to false to only run skills you type explicitly.
#
# routing_declined: false   # Set to true to skip the CLAUDE.md routing injection
#                           # prompt. Set back to false to be asked again.
# global_claude_declined: false
#                           # Set to true to skip the ~/.claude/CLAUDE.md prompt
#                           # during setup. Set back to false to be asked again.
#
# ─── Updates ─────────────────────────────────────────────────────────
# release_channel: stable   # stable = published release channel for user upgrades
#                           # reserved future values: candidate, nightly
# auto_upgrade: false       # true = silently upgrade on session start
# update_check: true        # false = suppress version check notifications
#
# ─── Execution ───────────────────────────────────────────────────────
# execution_mode: governed_ccb
#                           # governed_ccb = Claude -> Nexus -> CCB -> Codex/Gemini
#                           # local_provider = Nexus uses a local Claude/Codex/Gemini CLI
#                           # interactive Claude setup asks which mode to prefer
#                           # when CCB is detected and no explicit mode is saved yet
# primary_provider: claude  # local_provider only, ignored by governed_ccb
# provider_topology: single_agent
#                           # local_provider only, ignored by governed_ccb
#                           # active local topologies:
#                           # subagents = claude, codex, or gemini
#                           # multi_session = codex only
#
# ─── Skill naming ────────────────────────────────────────────────────
# skill_prefix: false       # true = namespace skills as /nexus-qa, /nexus-ship
#                           # false = short names /qa, /ship
#
# ─── Advanced ────────────────────────────────────────────────────────
# codex_reviews: enabled    # disabled = skip Codex adversarial reviews in /ship
# nexus_contributor: false  # true = file field reports when Nexus misbehaves
# skip_eng_review: false    # true = skip eng review gate in /ship (not recommended)
#
'

get_value() {
  local key="$1"
  grep -E "^${key}:" "$CONFIG_FILE" 2>/dev/null | tail -1 | awk '{print $2}' | tr -d '[:space:]' || true
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

csv_contains() {
  local csv="$1"
  local needle="$2"
  case ",$csv," in
    *",$needle,"*) return 0 ;;
    *) return 1 ;;
  esac
}

read_mounted_providers_csv() {
  command_exists ccb-mounted || return 0

  local mounted_json mounted_inner mounted_csv
  mounted_json="$(ccb-mounted --autostart 2>/dev/null || true)"
  [ -n "$mounted_json" ] || return 0

  mounted_inner="$(
    printf '%s' "$mounted_json" |
      tr -d '\n' |
      sed -n 's/.*"mounted"[[:space:]]*:[[:space:]]*\[\([^]]*\)\].*/\1/p'
  )"
  [ -n "$mounted_inner" ] || return 0

  mounted_csv="$(printf '%s' "$mounted_inner" | tr -d '"' | tr -d '[:space:]')"
  printf '%s' "$mounted_csv"
}

default_local_provider() {
  if command_exists claude; then
    printf 'claude'
  elif command_exists codex; then
    printf 'codex'
  elif command_exists gemini; then
    printf 'gemini'
  else
    printf 'claude'
  fi
}

print_effective_execution() {
  local configured_mode configured_provider configured_topology ccb_available
  local mode primary_provider provider_topology requested_execution_path mode_configured
  local mounted_providers_csv missing_providers_csv required_governed_providers governed_ready
  local provider_cli_available current_session_ready execution_mode_source
  local local_provider local_provider_topology local_provider_requested_execution_path local_provider_ready

  configured_mode="$(get_value execution_mode)"
  configured_provider="$(get_value primary_provider)"
  configured_topology="$(get_value provider_topology)"
  required_governed_providers="codex,gemini"

  if command_exists ask; then
    ccb_available="yes"
  else
    ccb_available="no"
  fi

  mounted_providers_csv=""
  missing_providers_csv=""
  governed_ready="no"
  if [ "$ccb_available" = "yes" ]; then
    mounted_providers_csv="$(read_mounted_providers_csv)"
    if [ -n "$mounted_providers_csv" ]; then
      for provider in codex gemini; do
        if ! csv_contains "$mounted_providers_csv" "$provider"; then
          missing_providers_csv="${missing_providers_csv:+$missing_providers_csv,}$provider"
        fi
      done
    else
      missing_providers_csv="$required_governed_providers"
    fi
    if [ -z "$missing_providers_csv" ]; then
      governed_ready="yes"
    fi
  else
    missing_providers_csv="$required_governed_providers"
  fi

  if [ -n "$configured_provider" ]; then
    local_provider="$configured_provider"
  else
    local_provider="$(default_local_provider)"
  fi
  if [ -n "$configured_topology" ]; then
    local_provider_topology="$configured_topology"
  else
    local_provider_topology="single_agent"
  fi
  local_provider_requested_execution_path="${local_provider}-local-${local_provider_topology}"
  if command_exists "$local_provider"; then
    provider_cli_available="yes"
    local_provider_ready="yes"
  else
    provider_cli_available="no"
    local_provider_ready="no"
  fi

  if [ -n "$configured_mode" ]; then
    mode="$configured_mode"
    mode_configured="yes"
    execution_mode_source="persisted_preference"
  else
    mode_configured="no"
    if [ "$governed_ready" = "yes" ]; then
      mode="governed_ccb"
      execution_mode_source="machine_default_governed_ready"
    elif [ "$ccb_available" = "yes" ]; then
      mode="local_provider"
      execution_mode_source="machine_default_local_governed_not_ready"
    else
      mode="local_provider"
      execution_mode_source="machine_default_local_ccb_missing"
    fi
  fi

  if [ "$mode" = "governed_ccb" ]; then
    primary_provider="codex"
    provider_topology="multi_session"
    requested_execution_path="codex-via-ccb"
    current_session_ready="$governed_ready"

    cat <<EOF
execution_mode: $mode
execution_mode_configured: $mode_configured
execution_mode_source: $execution_mode_source
ccb_available: $ccb_available
effective_primary_provider: $primary_provider
effective_provider_topology: $provider_topology
effective_requested_execution_path: $requested_execution_path
current_session_ready: $current_session_ready
required_governed_providers: $required_governed_providers
mounted_providers: ${mounted_providers_csv:-none}
missing_providers: ${missing_providers_csv:-none}
governed_ready: $governed_ready
local_provider_candidate: $local_provider
local_provider_topology: $local_provider_topology
local_provider_requested_execution_path: $local_provider_requested_execution_path
local_provider_ready: $local_provider_ready
provider_cli_available: $provider_cli_available
note: primary_provider and provider_topology are local_provider-only config keys and may be unset when execution_mode=governed_ccb
EOF
    return 0
  fi

  primary_provider="$local_provider"
  provider_topology="$local_provider_topology"
  requested_execution_path="$local_provider_requested_execution_path"
  current_session_ready="$local_provider_ready"

  cat <<EOF
execution_mode: $mode
execution_mode_configured: $mode_configured
execution_mode_source: $execution_mode_source
ccb_available: $ccb_available
effective_primary_provider: $primary_provider
effective_provider_topology: $provider_topology
effective_requested_execution_path: $requested_execution_path
provider_cli_available: $provider_cli_available
current_session_ready: $current_session_ready
required_governed_providers: $required_governed_providers
mounted_providers: ${mounted_providers_csv:-none}
missing_providers: ${missing_providers_csv:-none}
governed_ready: $governed_ready
local_provider_candidate: $local_provider
local_provider_topology: $local_provider_topology
local_provider_requested_execution_path: $local_provider_requested_execution_path
local_provider_ready: $local_provider_ready
EOF
}

case "${1:-}" in
  -h|--help)
    awk '
      NR == 1 { next }
      /^set -euo pipefail$/ { exit }
      /^# / { sub(/^# /, ""); print; next }
      /^#$/ { print ""; next }
    ' "$0"
    exit 0
    ;;
  get)
    KEY="${2:?Usage: nexus-config get <key>}"
    if ! printf '%s' "$KEY" | grep -qE '^[a-zA-Z0-9_]+$'; then
      echo "Error: key must contain only alphanumeric characters and underscores" >&2
      exit 1
    fi
    VALUE="$(get_value "$KEY")"
    printf '%s' "$VALUE"
    ;;
  set)
    KEY="${2:?Usage: nexus-config set <key> <value>}"
    VALUE="${3:?Usage: nexus-config set <key> <value>}"
    if ! printf '%s' "$KEY" | grep -qE '^[a-zA-Z0-9_]+$'; then
      echo "Error: key must contain only alphanumeric characters and underscores" >&2
      exit 1
    fi
    mkdir -p "$STATE_DIR"
    if [ ! -f "$CONFIG_FILE" ]; then
      printf '%s' "$CONFIG_HEADER" > "$CONFIG_FILE"
    fi
    ESC_VALUE="$(printf '%s' "$VALUE" | head -1 | sed 's/[&/\]/\\&/g')"
    if grep -qE "^${KEY}:" "$CONFIG_FILE" 2>/dev/null; then
      _tmpfile="$(mktemp "${CONFIG_FILE}.XXXXXX")"
      sed "/^${KEY}:/s/.*/${KEY}: ${ESC_VALUE}/" "$CONFIG_FILE" > "$_tmpfile" && mv "$_tmpfile" "$CONFIG_FILE"
    else
      echo "${KEY}: ${VALUE}" >> "$CONFIG_FILE"
    fi
    if [ "$KEY" = "skill_prefix" ] && [ -z "${NEXUS_SETUP_RUNNING:-}" ]; then
      NEXUS_RELINK="$(dirname "$0")/nexus-relink"
      [ -x "$NEXUS_RELINK" ] && "$NEXUS_RELINK" || true
    fi
    ;;
  list)
    cat "$CONFIG_FILE" 2>/dev/null || true
    ;;
  effective-execution)
    print_effective_execution
    ;;
  *)
    echo "Usage: nexus-config {get|set|list|effective-execution} [key] [value]"
    exit 1
    ;;
esac
