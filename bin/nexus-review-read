#!/usr/bin/env bash
# nexus-review-read — read review log and config for dashboard
# Usage: nexus-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/nexus-slug" 2>/dev/null)"
STATE_DIR="${NEXUS_STATE_DIR:-$HOME/.nexus}"
cat "$STATE_DIR/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/nexus-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
