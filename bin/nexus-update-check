#!/usr/bin/env bash
# nexus-update-check — periodic version check for the Nexus host layer.
#
# Output (one line, or nothing):
#   JUST_UPGRADED <old> <new>       — legacy marker found from recent upgrade
#   UPGRADE_AVAILABLE <old> <new>   — remote release differs from local
#   (nothing)                       — up to date, snoozed, disabled, invalid, or skipped
#
# Env overrides (for testing):
#   NEXUS_DIR               — override auto-detected install root
#   NEXUS_STATE_DIR         — override the Nexus state directory
#   NEXUS_RELEASE_REPO      — override the GitHub repo slug
#   NEXUS_RELEASE_DISCOVERY_URL  — override release discovery URL
#   NEXUS_RELEASE_MANIFEST_URL   — override candidate release.json URL
set -euo pipefail

FORCE_CHECK=0
case "${1:-}" in
  -h|--help)
    awk '
      NR == 1 { next }
      /^set -euo pipefail$/ { exit }
      /^# / { sub(/^# /, ""); print; next }
      /^#$/ { print ""; next }
    ' "$0"
    exit 0
    ;;
  --force)
    FORCE_CHECK=1
    ;;
  "")
    ;;
  *)
    echo "Unknown option: ${1}" >&2
    echo "Usage: nexus-update-check [--force]" >&2
    exit 1
    ;;
esac

NEXUS_DIR="${NEXUS_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
STATE_DIR="${NEXUS_STATE_DIR:-$HOME/.nexus}"
VERSION_FILE="$NEXUS_DIR/VERSION"
INSTALL_METADATA_FILE="$NEXUS_DIR/.nexus-install.json"
UPDATE_STATE_DIR="$STATE_DIR/update-state"
LAST_CHECK_FILE="$UPDATE_STATE_DIR/last-check.json"
SNOOZE_JSON_FILE="$UPDATE_STATE_DIR/snooze.json"
JUST_UPGRADED_JSON_FILE="$UPDATE_STATE_DIR/just-upgraded.json"
LEGACY_CACHE_FILE="$STATE_DIR/last-update-check"
LEGACY_MARKER_FILE="$STATE_DIR/just-upgraded-from"
LEGACY_SNOOZE_FILE="$STATE_DIR/update-snoozed"

if [ "$FORCE_CHECK" -eq 1 ]; then
  rm -f "$LAST_CHECK_FILE" "$SNOOZE_JSON_FILE" "$LEGACY_CACHE_FILE" "$LEGACY_SNOOZE_FILE"
fi

_UC=$("$NEXUS_DIR/bin/nexus-config" get update_check 2>/dev/null || true)
if [ "$_UC" = "false" ]; then
  exit 0
fi

if [ ! -f "$STATE_DIR/.codex-desc-healed" ]; then
  for _AGENTS_SKILL in "$NEXUS_DIR"/.agents/skills/*/SKILL.md; do
    [ -f "$_AGENTS_SKILL" ] || continue
    _DESC=$(awk '/^---$/{n++;next}n==1&&/^description:/{d=1;sub(/^description:\s*/,"");if(length>0)print;next}d&&/^  /{sub(/^  /,"");print;next}d{d=0}' "$_AGENTS_SKILL" | wc -c | tr -d ' ')
    if [ "${_DESC:-0}" -gt 1024 ]; then
      rm -f "$_AGENTS_SKILL"
    fi
  done
  mkdir -p "$STATE_DIR"
  touch "$STATE_DIR/.codex-desc-healed"
fi

RELEASE_CHANNEL="${NEXUS_RELEASE_CHANNEL:-${RELEASE_CHANNEL:-$("$NEXUS_DIR/bin/nexus-config" get release_channel 2>/dev/null || true)}}"

mkdir -p "$STATE_DIR"

CORE_JS="$(cat <<'EOF'
const { existsSync, mkdirSync, readFileSync, rmSync, writeFileSync } = await import('fs');
const { dirname, join } = await import('path');
const releaseContract = await import(process.env.NEXUS_RELEASE_CONTRACT_PATH);
const installMetadata = await import(process.env.NEXUS_INSTALL_METADATA_PATH);
const updateState = await import(process.env.NEXUS_UPDATE_STATE_PATH);

const nexusDir = process.env.NEXUS_DIR ?? process.cwd();
const stateRoot = process.env.NEXUS_STATE_DIR ?? join(process.env.HOME ?? '', '.nexus');
const releaseChannel = (process.env.NEXUS_RELEASE_CHANNEL ?? 'stable').trim() || 'stable';
const versionPath = join(nexusDir, 'VERSION');
const metadataPath = join(nexusDir, '.nexus-install.json');
const installMetadataState = readInstallMetadata();
const repoSlug =
  (process.env.NEXUS_RELEASE_REPO ?? '').trim() ||
  await resolveRepoSlug(nexusDir, installMetadataState === '__invalid__' ? null : installMetadataState);
const updateStateDir = join(stateRoot, 'update-state');
const lastCheckPath = join(updateStateDir, updateState.LAST_CHECK_FILE);
const snoozeJsonPath = join(updateStateDir, updateState.SNOOZE_FILE);
const justUpgradedJsonPath = join(updateStateDir, updateState.JUST_UPGRADED_FILE);
const legacyJustUpgradedPath = updateState.getLegacyJustUpgradedPath(stateRoot);
const legacySnoozePath = updateState.getLegacySnoozePath(stateRoot);

const supportedChannels = new Set(releaseContract.RELEASE_CHANNELS);

function nowIso() {
  return new Date().toISOString();
}

function writeJson(path, value) {
  mkdirSync(dirname(path), { recursive: true });
  writeFileSync(path, `${JSON.stringify(value, null, 2)}\n`);
}

function readJson(path, validator) {
  if (!existsSync(path)) {
    return null;
  }

  try {
    return validator(JSON.parse(readFileSync(path, 'utf8')));
  } catch {
    return null;
  }
}

function readInstallMetadata() {
  if (!existsSync(metadataPath)) {
    return null;
  }

  try {
    return installMetadata.validateInstallMetadata(JSON.parse(readFileSync(metadataPath, 'utf8')));
  } catch {
    return '__invalid__';
  }
}

function readStructuredLastCheckState() {
  return readJson(lastCheckPath, updateState.validateLastCheckUpdateState);
}

function readStructuredJustUpgradedState() {
  return readJson(justUpgradedJsonPath, updateState.validateJustUpgradedUpdateState);
}

function localVersionFrom(versionText, metadata) {
  if (versionText.length > 0) {
    return versionText;
  }

  return metadata?.installed_version ?? '';
}

function localTagFrom(version, metadata) {
  if (metadata) {
    return metadata.installed_tag;
  }

  return `v${version}`;
}

function writeLastCheckState(status, localVersion, localTag, candidateVersion, candidateTag) {
  const state = {
    schema_version: 1,
    status,
    checked_at: nowIso(),
    release_channel: releaseChannel,
    local_version: localVersion,
    local_tag: localTag,
    candidate_version: candidateVersion,
    candidate_tag: candidateTag,
    source: {
      kind: 'github_release',
      repo: repoSlug,
    },
  };

  updateState.validateLastCheckUpdateState(state);
  writeJson(lastCheckPath, state);
}

function writeSnoozeState(candidateVersion, candidateTag, snoozeLevel, snoozedEpoch) {
  const normalizedEpoch = Math.floor(snoozedEpoch);
  const snoozedAt = new Date(normalizedEpoch * 1000).toISOString();
  const expiresAt = new Date((normalizedEpoch + snoozeDurationSeconds(snoozeLevel)) * 1000).toISOString();
  const state = {
    schema_version: 1,
    release_channel: releaseChannel,
    candidate_version: candidateVersion,
    candidate_tag: candidateTag,
    snooze_level: snoozeLevel,
    snoozed_at: snoozedAt,
    expires_at: expiresAt,
  };

  updateState.validateSnoozeUpdateState(state);
  writeJson(snoozeJsonPath, state);
}

function writeJustUpgradedState(fromVersion, toVersion, toTag) {
  const state = {
    schema_version: 1,
    from_version: fromVersion,
    from_tag: `v${fromVersion}`,
    to_version: toVersion,
    to_tag: toTag,
    release_channel: releaseChannel,
    completed_at: nowIso(),
  };

  updateState.validateJustUpgradedUpdateState(state);
  writeJson(justUpgradedJsonPath, state);
}

function normalizeLegacyJustUpgradedState(localVersion, localTag) {
  const legacyMarker = updateState.readLegacyJustUpgradedMarker(stateRoot);
  if (legacyMarker === null) {
    return;
  }

  writeJustUpgradedState(legacyMarker.from_version, localVersion, localTag);
  rmSync(legacyJustUpgradedPath, { force: true });
  rmSync(legacySnoozePath, { force: true });
  rmSync(snoozeJsonPath, { force: true });
}

function snoozeDurationSeconds(level) {
  if (level === 1) {
    return 86400;
  }

  if (level === 2) {
    return 172800;
  }

  return 604800;
}

function parseRepoSlug(remoteUrl) {
  if (remoteUrl.startsWith('git@github.com:')) {
    return remoteUrl.slice('git@github.com:'.length).replace(/\.git$/, '');
  }

  if (remoteUrl.startsWith('https://github.com/')) {
    return remoteUrl.slice('https://github.com/'.length).replace(/\.git$/, '');
  }

  return '';
}

async function resolveRepoSlug(root, metadata) {
  const metadataRepo = metadata?.install_source?.repo?.trim() ?? '';
  if (metadataRepo.length > 0) {
    return metadataRepo;
  }

  const result = Bun.spawnSync(['git', '-C', root, 'remote', 'get-url', 'origin'], {
    stdout: 'pipe',
    stderr: 'pipe',
  });
  if (result.exitCode !== 0) {
    return 'unknown';
  }

  const remoteUrl = result.stdout.toString().trim();
  return parseRepoSlug(remoteUrl) || 'unknown';
}

async function loadText(ref) {
  if (ref.startsWith('file://')) {
    return Bun.file(new URL(ref)).text();
  }

  if (ref.startsWith('http://') || ref.startsWith('https://')) {
    const response = await fetch(ref, {
      headers: {
        accept: 'application/vnd.github+json',
        'user-agent': 'nexus-update-check',
      },
    });
    if (!response.ok) {
      throw new Error(`failed to fetch ${ref}: ${response.status} ${response.statusText}`);
    }

    return response.text();
  }

  return readFileSync(ref, 'utf8');
}

async function loadJson(ref, label, validator) {
  const text = await loadText(ref);
  const parsed = JSON.parse(text);
  return validator(parsed);
}

function extractDiscoveryCandidate(discovery) {
  const tag = typeof discovery.tag_name === 'string' && discovery.tag_name.trim().length > 0
    ? discovery.tag_name.trim()
    : typeof discovery.tag === 'string' && discovery.tag.trim().length > 0
      ? discovery.tag.trim()
      : '';
  const version = typeof discovery.version === 'string' && discovery.version.trim().length > 0
    ? discovery.version.trim()
    : tag.startsWith('v')
      ? tag.slice(1)
      : tag;
  const manifestUrl = typeof discovery.manifest_url === 'string' && discovery.manifest_url.trim().length > 0
    ? discovery.manifest_url.trim()
    : process.env.NEXUS_RELEASE_MANIFEST_URL?.trim() || `https://raw.githubusercontent.com/${repoSlug}/${tag}/release.json`;
  const bundleUrl = typeof discovery.bundle_url === 'string' && discovery.bundle_url.trim().length > 0
    ? discovery.bundle_url.trim()
    : null;

  return { tag, version, manifestUrl, bundleUrl };
}

function readLegacySnoozeState() {
  const structured = readJson(snoozeJsonPath, updateState.validateSnoozeUpdateState);
  if (structured !== null) {
    return structured;
  }

  const legacy = updateState.readLegacySnoozeMarker(stateRoot);
  if (legacy === null) {
    return null;
  }

  const snoozedAt = new Date(legacy.snoozed_epoch * 1000).toISOString();
  const expiresAt = new Date((legacy.snoozed_epoch + snoozeDurationSeconds(legacy.snooze_level)) * 1000).toISOString();
  const converted = {
    schema_version: 1,
    release_channel: releaseChannel,
    candidate_version: legacy.candidate_version,
    candidate_tag: `v${legacy.candidate_version}`,
    snooze_level: legacy.snooze_level,
    snoozed_at: snoozedAt,
    expires_at: expiresAt,
  };

  updateState.validateSnoozeUpdateState(converted);
  return converted;
}

function isSnoozeActive(snoozeState, candidateVersion, candidateTag) {
  if (!snoozeState) {
    return false;
  }

  if (snoozeState.candidate_version !== candidateVersion) {
    return false;
  }

  if (snoozeState.candidate_tag !== candidateTag) {
    return false;
  }

  return Date.parse(snoozeState.expires_at) > Date.now();
}

function recordError(status, localVersion, localTag, candidateVersion = null, candidateTag = null) {
  writeLastCheckState(status, localVersion, localTag, candidateVersion, candidateTag);
}

if (!supportedChannels.has(releaseChannel)) {
  const versionText = existsSync(versionPath) ? readFileSync(versionPath, 'utf8').trim() : '';
  const metadata = installMetadataState;
  if (metadata === '__invalid__') {
    const localVersion = versionText.length > 0 ? versionText : 'unknown';
    recordError('error', localVersion, versionText.length > 0 ? `v${versionText}` : 'unknown');
    process.exit(0);
  }
  const localVersion = localVersionFrom(versionText, metadata);
  if (localVersion.length > 0) {
    const localTag = localTagFrom(localVersion, metadata);
    recordError('error', localVersion, localTag);
  }
  process.exit(0);
}

const versionText = existsSync(versionPath) ? readFileSync(versionPath, 'utf8').trim() : '';
const metadata = installMetadataState;
if (metadata === '__invalid__') {
  const localVersion = versionText.length > 0 ? versionText : 'unknown';
  recordError('error', localVersion, versionText.length > 0 ? `v${versionText}` : 'unknown');
  process.exit(0);
}
if (metadata && versionText.length > 0 && metadata.installed_version !== versionText) {
  recordError('error', versionText, `v${versionText}`);
  process.exit(0);
}
if (metadata && metadata.installed_tag !== `v${metadata.installed_version}`) {
  const localVersion = localVersionFrom(versionText, metadata);
  recordError('error', localVersion, localTagFrom(localVersion, metadata));
  process.exit(0);
}

const localVersion = localVersionFrom(versionText, metadata);
if (localVersion.length === 0) {
  process.exit(0);
}
const localTag = localTagFrom(localVersion, metadata);

normalizeLegacyJustUpgradedState(localVersion, localTag);

const justUpgradedState = readStructuredJustUpgradedState();
const lastCheckStateForProjection = readStructuredLastCheckState();

let discovery = null;
let candidateVersion = null;
let candidateTag = null;
let manifestUrl = null;
let bundleUrl = null;
try {
  const discoveryUrl = process.env.NEXUS_RELEASE_DISCOVERY_URL?.trim() || `https://api.github.com/repos/${repoSlug}/releases/latest`;
  discovery = await loadJson(discoveryUrl, 'release discovery', value => value);
  if (typeof discovery !== 'object' || discovery === null || Array.isArray(discovery)) {
    throw new Error('release discovery must be an object');
  }
  if (typeof discovery.channel === 'string' && discovery.channel.trim().length > 0 && discovery.channel !== releaseChannel) {
    throw new Error(`release discovery channel ${discovery.channel} does not match ${releaseChannel}`);
  }
  if (discovery.draft === true || discovery.prerelease === true) {
    throw new Error('release discovery selected a draft or prerelease');
  }
  const extracted = extractDiscoveryCandidate(discovery);
  candidateVersion = extracted.version;
  candidateTag = extracted.tag;
  manifestUrl = extracted.manifestUrl;
  bundleUrl = extracted.bundleUrl;
  if (candidateVersion.length === 0 || candidateTag.length === 0) {
    throw new Error('release discovery must include a tag or version');
  }
} catch (error) {
  recordError('error', localVersion, localTag);
  process.exit(0);
}

let manifest = null;
try {
  manifest = await loadJson(manifestUrl, 'release manifest', value => {
    releaseContract.assertReleaseManifest(value);
    return value;
  });
} catch (error) {
  recordError('invalid_remote', localVersion, localTag, candidateVersion, candidateTag);
  process.exit(0);
}

if (manifest.channel !== releaseChannel) {
  recordError('invalid_remote', localVersion, localTag, candidateVersion, candidateTag);
  process.exit(0);
}

if (manifest.version !== candidateVersion || manifest.tag !== candidateTag) {
  recordError('invalid_remote', localVersion, localTag, candidateVersion, candidateTag);
  process.exit(0);
}

if (bundleUrl !== null && manifest.bundle.url !== bundleUrl) {
  recordError('invalid_remote', localVersion, localTag, candidateVersion, candidateTag);
  process.exit(0);
}

const justUpgradedMatchesCurrentRelease =
  justUpgradedState !== null &&
  justUpgradedState.to_version === candidateVersion &&
  justUpgradedState.to_tag === candidateTag;

if (justUpgradedMatchesCurrentRelease) {
  rmSync(snoozeJsonPath, { force: true });
  rmSync(legacySnoozePath, { force: true });
}

const snoozeState = readLegacySnoozeState();
if (!justUpgradedMatchesCurrentRelease && isSnoozeActive(snoozeState, candidateVersion, candidateTag)) {
  writeSnoozeState(
    snoozeState.candidate_version,
    snoozeState.candidate_tag,
    snoozeState.snooze_level,
    Math.floor(Date.parse(snoozeState.snoozed_at) / 1000),
  );
  writeLastCheckState('snoozed', localVersion, localTag, candidateVersion, candidateTag);
  process.exit(0);
}

const status = candidateVersion === localVersion && candidateTag === localTag ? 'up_to_date' : 'upgrade_available';
writeLastCheckState(status, localVersion, localTag, candidateVersion, candidateTag);

if (
  justUpgradedState !== null &&
  (
    lastCheckStateForProjection === null ||
    Date.parse(justUpgradedState.completed_at) > Date.parse(lastCheckStateForProjection.checked_at)
  )
) {
  console.log(`JUST_UPGRADED ${justUpgradedState.from_version} ${justUpgradedState.to_version}`);
}

if (status === 'upgrade_available') {
  console.log(`UPGRADE_AVAILABLE ${localVersion} ${candidateVersion}`);
}
EOF
)"

NEXUS_DIR="$NEXUS_DIR" \
NEXUS_STATE_DIR="$STATE_DIR" \
NEXUS_RELEASE_CHANNEL="$RELEASE_CHANNEL" \
NEXUS_RELEASE_CONTRACT_PATH="$NEXUS_DIR/lib/nexus/release-contract.ts" \
NEXUS_INSTALL_METADATA_PATH="$NEXUS_DIR/lib/nexus/install-metadata.ts" \
NEXUS_UPDATE_STATE_PATH="$NEXUS_DIR/lib/nexus/update-state.ts" \
NEXUS_RELEASE_REPO="${NEXUS_RELEASE_REPO:-}" \
NEXUS_RELEASE_DISCOVERY_URL="${NEXUS_RELEASE_DISCOVERY_URL:-}" \
NEXUS_RELEASE_MANIFEST_URL="${NEXUS_RELEASE_MANIFEST_URL:-}" \
bun -e "$CORE_JS"
